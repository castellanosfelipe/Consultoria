---
import { siteConfig } from "../config";
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label={`${siteConfig.name}, inicio`}>
      <span class="brand-mark" aria-hidden="true">FP</span>
      <span class="brand-copy">
        <strong>{siteConfig.name}</strong>
        <span>software de operaciones</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Navegación principal">
      <a href="/#servicios">Servicios</a>
      <a href="/#prueba">Compromisos</a>
      <a href="/#proceso">Proceso</a>
      <a href="/#contacto" class="nav-cta" data-track="cta" data-location="header">Hablemos <span class="icon-arrow icon-arrow--down" aria-hidden="true"></span></a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    min-height: var(--header-height);
    border-bottom: var(--border) solid var(--line);
    background: color-mix(in srgb, var(--paper) 94%, transparent);
  }

  .header-inner {
    min-height: var(--header-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
  }

  .brand {
    display: inline-flex;
    min-height: var(--target);
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
  }

  .brand-mark {
    display: inline-grid;
    width: var(--target);
    height: var(--target);
    place-items: center;
    border: var(--border-strong) solid var(--ink);
    border-radius: var(--radius);
    font-family: var(--font-data);
    font-size: var(--text-label);
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .brand-copy {
    display: flex;
    flex-direction: column;
    font-size: var(--text-micro);
    line-height: 1.25;
  }

  .brand-copy strong {
    font-weight: 600;
  }

  .brand-copy span {
    color: var(--graphite);
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: clamp(var(--space-3), 2.4vw, var(--space-6));
    font-size: var(--text-micro);
  }

  .site-nav a {
    min-height: var(--target);
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }

  .site-nav a:not(.nav-cta) {
    color: var(--graphite);
  }

  .site-nav a:not(.nav-cta):hover {
    color: var(--ink);
  }

  .nav-cta {
    gap: var(--space-2);
    border-bottom: var(--border-strong) solid var(--production);
    color: var(--production);
    font-weight: 600;
  }

  @media (max-width: 43.75rem) {
    .brand-copy,
    .site-nav a:not(.nav-cta) {
      display: none;
    }

    .site-nav {
      margin-left: auto;
    }
  }
</style>
