---
import { siteConfig, withBasePath } from "../config";
import { getCopy, type Language } from "../i18n/copy";

interface Props {
  lang?: Language;
}

const { lang = "es" } = Astro.props;
const t = getCopy(lang);
const homeHref = withBasePath(lang === "en" ? "/en/" : "/");
const spanishHref = withBasePath("/");
const englishHref = withBasePath("/en/");
const sectionHref = (id: string) => `${homeHref}#${id}`;
const currencyOptions = [
  { value: "COP", country: "CO", label: t.header.currencyColombia },
  { value: "MXN", country: "MX", label: t.header.currencyMexico },
  { value: "PEN", country: "PE", label: t.header.currencyPeru },
  { value: "USD", country: "US", label: t.header.currencyInternational },
] as const;
---

<header class="site-header" data-scroll-header>
  <div class="container header-inner">
    <a class="brand" href={homeHref}>
      <span class="brand-mark">FP<span class="brand-status" aria-hidden="true"></span></span>
      <span class="brand-copy">
        <strong>{siteConfig.name}</strong>
        <span>{t.header.product}</span>
      </span>
      <span class="sr-only">{t.header.home}</span>
    </a>

    <nav class="site-nav" aria-label={t.header.navigation}>
      <div class="site-nav__desktop" data-nav-links>
        <a href={sectionHref("servicios")}>{t.header.services}</a>
        <a href={sectionHref("prueba")}>{t.header.commitments}</a>
        <a href={sectionHref("proceso")}>{t.header.process}</a>
        <a href={sectionHref("contacto")} class="nav-cta" data-track="cta" data-location="header">{t.header.talk} <span class="icon-arrow icon-arrow--down" aria-hidden="true"></span></a>
        <div class="language-switch" role="group" aria-label={t.header.language}>
          <a href={spanishHref} lang="es" hreflang="es-CO" aria-label={t.header.switchToSpanish} aria-current={lang === "es" ? "page" : undefined} data-language-link>ES</a>
          <span aria-hidden="true">/</span>
          <a href={englishHref} lang="en" hreflang="en" aria-label={t.header.switchToEnglish} aria-current={lang === "en" ? "page" : undefined} data-language-link>EN</a>
        </div>
      </div>

      <div class="site-nav__mobile-controls">
        <button
          class="menu-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="navegacion-movil"
          data-menu-toggle
        >
          <span data-menu-label>{t.header.menu}</span>
          <span class="menu-toggle__icon" aria-hidden="true"><span></span><span></span><span></span></span>
        </button>
        <div class="language-switch" role="group" aria-label={t.header.language}>
          <a href={spanishHref} lang="es" hreflang="es-CO" aria-label={t.header.switchToSpanish} aria-current={lang === "es" ? "page" : undefined} data-language-link>ES</a>
          <span aria-hidden="true">/</span>
          <a href={englishHref} lang="en" hreflang="en" aria-label={t.header.switchToEnglish} aria-current={lang === "en" ? "page" : undefined} data-language-link>EN</a>
        </div>
      </div>

      <label class="currency-switch">
        <span class="sr-only">{t.header.currency}</span>
        <select data-currency-select aria-label={t.header.currency}>
          {currencyOptions.map((option) => (
            <option
              value={option.value}
              data-country={option.country}
              selected={option.value === "COP"}
            >
              {option.label}
            </option>
          ))}
        </select>
        <span class="currency-switch__arrow" aria-hidden="true"></span>
      </label>

      <div class="site-nav__mobile" id="navegacion-movil" data-mobile-menu data-nav-links hidden inert aria-hidden="true">
        <a href={sectionHref("servicios")}>{t.header.services}</a>
        <a href={sectionHref("prueba")}>{t.header.commitments}</a>
        <a href={sectionHref("proceso")}>{t.header.process}</a>
        <a href={sectionHref("contacto")} class="nav-cta" data-track="cta" data-location="header-mobile">{t.header.talk}</a>
      </div>

      <noscript>
        <div class="site-nav__noscript">
          <a href={sectionHref("servicios")}>{t.header.services}</a>
          <a href={sectionHref("prueba")}>{t.header.commitments}</a>
          <a href={sectionHref("proceso")}>{t.header.process}</a>
          <a href={sectionHref("contacto")}>{t.header.talk}</a>
        </div>
      </noscript>
    </nav>
  </div>
</header>

<noscript>
  <style>
    @media (max-width: 43.75rem) {
      [data-menu-toggle] { display: none !important; }
    }
  </style>
</noscript>

<style>
  .site-header {
    position: sticky;
    z-index: 40;
    top: 0;
    min-height: var(--header-height);
    isolation: isolate;
    border-bottom: var(--border) solid var(--line);
    background: transparent;
    font-family: var(--font-body-fallback);
  }

  .site-header::before {
    position: absolute;
    z-index: 0;
    inset: 0;
    background: color-mix(in srgb, var(--paper) 84%, transparent);
    backdrop-filter: blur(var(--space-3));
    content: "";
    opacity: 1;
    pointer-events: none;
    transition: opacity var(--motion-fast) var(--motion-ease);
  }

  /* El rail confirma que la navegación pasó de estado inicial a sticky. */
  .site-header::after {
    position: absolute;
    z-index: 2;
    right: 0;
    bottom: calc(-1 * var(--border));
    left: 0;
    height: var(--border-strong);
    background: var(--production);
    content: "";
    opacity: 0;
    pointer-events: none;
    transform: scaleX(0);
    transform-origin: left center;
    transition:
      opacity 320ms var(--motion-ease),
      transform 480ms var(--motion-ease);
  }

  .site-header:not(.is-scrolled)::before {
    opacity: 0;
  }

  .site-header.is-scrolled::before {
    opacity: 1;
  }

  .site-header.is-scrolled::after {
    opacity: 1;
    transform: scaleX(var(--page-scroll-progress, 0));
  }

  .header-inner {
    position: relative;
    z-index: 1;
    min-height: var(--header-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
  }

  .brand {
    display: inline-flex;
    min-height: var(--target);
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
  }

  .brand-mark {
    position: relative;
    display: inline-grid;
    width: var(--target);
    height: var(--target);
    place-items: center;
    border: var(--border-strong) solid var(--ink);
    border-radius: var(--radius);
    font-family: var(--font-mark);
    font-size: var(--text-label);
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .brand-status {
    position: absolute;
    right: calc(-1 * var(--space-1));
    bottom: calc(-1 * var(--space-1));
    width: var(--space-2);
    height: var(--space-2);
    border: var(--border) solid var(--paper);
    border-radius: var(--radius-round);
    background: var(--production);
  }

  .brand-copy {
    display: flex;
    flex-direction: column;
    font-size: var(--text-micro);
    line-height: 1.25;
  }

  .brand-copy strong {
    font-weight: 600;
  }

  .brand-copy span {
    color: var(--graphite);
  }

  .site-nav,
  .site-nav__desktop,
  .site-nav__mobile-controls {
    display: flex;
    align-items: center;
  }

  .site-nav__desktop {
    gap: clamp(var(--space-3), 2.4vw, var(--space-6));
  }

  .language-switch {
    min-height: var(--target);
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
    padding-left: var(--space-2);
    border-left: var(--border) solid var(--line);
    color: var(--ink-muted);
    font-family: var(--font-data);
    font-size: var(--text-nano);
    letter-spacing: 0.08em;
  }

  .language-switch a {
    min-width: 1.85rem;
    justify-content: center;
    padding-inline: 0.2rem;
  }

  .language-switch a::after {
    display: none;
  }

  .currency-switch {
    position: relative;
    min-height: var(--target);
    display: inline-flex;
    align-items: center;
    margin-left: var(--space-2);
    padding-left: var(--space-3);
    border-left: var(--border) solid var(--line);
  }

  .currency-switch select {
    width: 6.2rem;
    min-height: var(--target);
    appearance: none;
    padding: 0 var(--space-5) 0 var(--space-2);
    border: var(--border) solid var(--line-strong);
    border-radius: var(--radius);
    background: var(--paper-raised);
    color: var(--ink);
    font-family: var(--font-data);
    font-size: var(--text-nano);
    font-weight: 600;
    letter-spacing: 0.04em;
    cursor: pointer;
  }

  .currency-switch select:hover {
    border-color: var(--ink-muted);
  }

  .currency-switch__arrow {
    position: absolute;
    right: var(--space-3);
    width: var(--space-2);
    height: var(--space-2);
    border-right: var(--border-strong) solid var(--production);
    border-bottom: var(--border-strong) solid var(--production);
    pointer-events: none;
    transform: translateY(calc(-1 * var(--space-1))) rotate(45deg);
  }

  .site-nav .language-switch a[aria-current="page"] {
    color: var(--production);
    font-weight: 600;
  }

  .site-nav {
    font-size: var(--text-micro);
  }

  .site-nav a,
  .menu-toggle {
    min-height: var(--target);
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }

  .site-nav a {
    position: relative;
  }

  .site-nav a::after {
    position: absolute;
    right: 0;
    bottom: var(--space-2);
    left: 0;
    height: var(--border-strong);
    background: var(--production);
    content: "";
    transform: scaleX(0);
    transform-origin: right center;
    transition: transform 320ms var(--motion-ease);
  }

  .site-nav a:hover::after,
  .site-nav a:focus-visible::after,
  .site-nav a[aria-current="location"]::after {
    transform: scaleX(1);
    transform-origin: left center;
  }

  .site-nav a:not(.nav-cta),
  .menu-toggle {
    color: var(--graphite);
  }

  .site-nav a:not(.nav-cta):hover,
  .menu-toggle:hover {
    color: var(--ink);
  }

  .site-nav a[aria-current="location"] {
    color: var(--ink);
  }

  .nav-cta {
    gap: var(--space-2);
    color: var(--production);
    font-weight: 600;
  }

  .nav-cta .icon-arrow,
  .menu-toggle__icon span {
    transition:
      opacity 300ms var(--motion-ease),
      transform 300ms var(--motion-ease);
  }

  .nav-cta:hover .icon-arrow,
  .nav-cta:focus-visible .icon-arrow {
    transform: translate(2px, 2px) rotate(var(--arrow-rotation));
  }

  .site-nav__mobile-controls,
  .site-nav__mobile,
  .site-nav__noscript {
    display: none;
  }

  .menu-toggle {
    gap: var(--space-2);
    padding: 0 var(--space-3);
    border: 0;
    background: transparent;
    font: inherit;
    cursor: pointer;
  }

  .menu-toggle__icon {
    position: relative;
    width: var(--space-4);
    height: var(--space-4);
    flex: 0 0 auto;
  }

  .menu-toggle__icon span {
    position: absolute;
    left: 0;
    width: 100%;
    height: var(--border-strong);
    background: currentColor;
    transform-origin: center;
  }

  .menu-toggle__icon span:first-child {
    top: calc(var(--space-1) / 2);
  }

  .menu-toggle__icon span:nth-child(2) {
    top: 50%;
    transform: translateY(-50%);
  }

  .menu-toggle__icon span:last-child {
    bottom: calc(var(--space-1) / 2);
  }

  .menu-toggle[aria-expanded="true"] .menu-toggle__icon span:first-child {
    top: 50%;
    transform: translateY(-50%) rotate(45deg);
  }

  .menu-toggle[aria-expanded="true"] .menu-toggle__icon span:last-child {
    bottom: 50%;
    transform: translateY(50%) rotate(-45deg);
  }

  .menu-toggle[aria-expanded="true"] .menu-toggle__icon span:nth-child(2) {
    opacity: 0;
  }

  /* Boot corto: primero identidad, después enlaces. No espera al script. */
  @media (prefers-reduced-motion: no-preference) {
    .brand-mark,
    .brand-copy,
    .site-nav__desktop > a,
    .site-nav__desktop > .language-switch,
    .site-nav > .currency-switch {
      animation: nav-boot 420ms var(--motion-ease) both;
    }

    .brand-copy {
      animation-delay: 55ms;
    }

    .site-nav__desktop > a:nth-child(1) {
      animation-delay: 110ms;
    }

    .site-nav__desktop > a:nth-child(2) {
      animation-delay: 160ms;
    }

    .site-nav__desktop > a:nth-child(3) {
      animation-delay: 210ms;
    }

    .site-nav__desktop > a:nth-child(4) {
      animation-delay: 260ms;
    }

    .site-nav__desktop > .language-switch {
      animation-delay: 310ms;
    }

    .site-nav > .currency-switch {
      animation-delay: 360ms;
    }

    .brand-status {
      animation: nav-status-online 320ms var(--motion-ease) 410ms both;
    }
  }

  @keyframes nav-boot {
    from {
      opacity: 0;
      transform: translateY(calc(-1 * var(--space-2))) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes nav-status-online {
    from {
      opacity: 0;
      transform: scale(0.4);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes nav-boot-fade {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @media (max-width: 43.75rem) {
    .brand-copy,
    .site-nav__desktop {
      display: none;
    }

    .site-nav {
      margin-left: auto;
    }

    .site-nav__mobile-controls {
      display: flex;
      gap: var(--space-2);
    }

    .currency-switch {
      margin-left: var(--space-2);
      padding-left: var(--space-2);
    }

    .currency-switch select {
      width: 5.75rem;
      padding-inline: var(--space-2) var(--space-5);
    }

    .site-nav__mobile-controls .language-switch {
      padding-left: var(--space-2);
    }

    .site-nav__mobile,
    .site-nav__noscript {
      position: absolute;
      z-index: 2;
      top: calc(100% + var(--border));
      right: 0;
      width: min(18rem, calc(100vw - (2 * var(--gutter))));
      padding: var(--space-3);
      border: var(--border) solid var(--line-strong);
      border-radius: var(--radius);
      background: var(--paper-raised);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--line);
    }

    /* JS retrasa `hidden` 300 ms: la salida usa solo opacity y conserva semántica. */
    .site-nav__mobile {
      opacity: 0;
      pointer-events: none;
      transition: opacity 300ms var(--motion-ease);
    }

    .site-nav__mobile:not([hidden]) {
      display: grid;
    }

    .site-nav__mobile.is-open {
      opacity: 1;
      pointer-events: auto;
    }

    .site-nav__noscript {
      display: grid;
    }

    .site-nav__mobile a,
    .site-nav__noscript a {
      padding-inline: var(--space-3);
    }

    .site-header::after {
      opacity: 0;
      transform: none;
      transition: opacity 300ms var(--motion-ease);
    }

    .site-header.is-scrolled::after {
      opacity: 1;
      transform: none;
    }

    @media (prefers-reduced-motion: no-preference) {
      .brand-mark,
      .brand-status,
      .site-nav__mobile-controls {
        animation: nav-boot-fade 320ms var(--motion-ease) both;
      }

      .brand-status {
        animation-delay: 180ms;
      }

      .site-nav__mobile-controls {
        animation-delay: 70ms;
      }
    }
  }

  @media (max-width: 23.4375rem) {
    .header-inner {
      gap: var(--space-2);
    }

    .site-nav__mobile-controls {
      gap: var(--space-1);
    }

    .site-nav__mobile-controls .language-switch {
      gap: 0;
      padding-left: 0;
      border-left: 0;
    }

    .language-switch a {
      min-width: var(--space-6);
      padding-inline: 0;
    }

    .menu-toggle {
      min-width: var(--target);
      justify-content: center;
      padding-inline: 0;
    }

    .menu-toggle [data-menu-label] {
      position: absolute;
      width: var(--border);
      height: var(--border);
      padding: 0;
      margin: calc(-1 * var(--border));
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
    }

    .currency-switch {
      margin-left: 0;
      padding-left: var(--space-1);
    }

    .currency-switch select {
      width: calc(var(--space-8) + var(--space-3));
      padding-inline: var(--space-1) var(--space-4);
    }

    .currency-switch__arrow {
      right: var(--space-2);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-mark,
    .brand-copy,
    .brand-status,
    .site-nav__desktop > a,
    .site-nav__desktop > .language-switch,
    .site-nav > .currency-switch,
    .site-nav__mobile-controls {
      opacity: 1;
      transform: none;
      animation: none;
    }

    .site-header::after,
    .site-nav a::after,
    .nav-cta .icon-arrow,
    .menu-toggle__icon span,
    .site-nav__mobile {
      transition: none;
    }
  }
</style>
