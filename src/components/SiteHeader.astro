---
import { siteConfig, withBasePath } from "../config";

const homeHref = withBasePath("/");
const sectionHref = (id: string) => `${homeHref}#${id}`;
---

<header class="site-header" data-scroll-header>
  <div class="container header-inner">
    <a class="brand" href={homeHref}>
      <span class="brand-mark">FP</span>
      <span class="brand-copy">
        <strong>{siteConfig.name}</strong>
        <span>software de operaciones</span>
      </span>
      <span class="sr-only">— inicio</span>
    </a>

    <nav class="site-nav" aria-label="Navegación principal">
      <div class="site-nav__desktop" data-nav-links>
        <a href={sectionHref("servicios")}>Servicios</a>
        <a href={sectionHref("prueba")}>Compromisos</a>
        <a href={sectionHref("proceso")}>Proceso</a>
        <a href={sectionHref("contacto")} class="nav-cta" data-track="cta" data-location="header">Hablemos <span class="icon-arrow icon-arrow--down" aria-hidden="true"></span></a>
      </div>

      <div class="site-nav__mobile-controls">
        <button
          class="menu-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="navegacion-movil"
          data-menu-toggle
        >
          <span data-menu-label>Menú</span>
          <span class="icon-arrow icon-arrow--down" aria-hidden="true"></span>
        </button>
        <a href={sectionHref("contacto")} class="nav-cta" data-track="cta" data-location="header-mobile">Hablemos</a>
      </div>

      <div class="site-nav__mobile" id="navegacion-movil" data-mobile-menu data-nav-links hidden>
        <a href={sectionHref("servicios")}>Servicios</a>
        <a href={sectionHref("prueba")}>Compromisos</a>
        <a href={sectionHref("proceso")}>Proceso</a>
      </div>

      <noscript>
        <div class="site-nav__noscript">
          <a href={sectionHref("servicios")}>Servicios</a>
          <a href={sectionHref("prueba")}>Compromisos</a>
          <a href={sectionHref("proceso")}>Proceso</a>
        </div>
      </noscript>
    </nav>
  </div>
</header>

<noscript>
  <style>
    @media (max-width: 43.75rem) {
      [data-menu-toggle] { display: none !important; }
    }
  </style>
</noscript>

<style>
  .site-header {
    position: sticky;
    z-index: 40;
    top: 0;
    min-height: var(--header-height);
    isolation: isolate;
    border-bottom: var(--border) solid var(--line);
    background: transparent;
    font-family: var(--font-body-fallback);
  }

  .site-header::before {
    position: absolute;
    z-index: 0;
    inset: 0;
    background: color-mix(in srgb, var(--paper) 84%, transparent);
    backdrop-filter: blur(var(--space-3));
    content: "";
    opacity: 1;
    pointer-events: none;
    transition: opacity var(--motion-fast) var(--motion-ease);
  }

  :global(.motion-ready) .site-header:not(.is-scrolled)::before {
    opacity: 0;
  }

  .site-header.is-scrolled::before {
    opacity: 1;
  }

  .header-inner {
    position: relative;
    z-index: 1;
    min-height: var(--header-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
  }

  .brand {
    display: inline-flex;
    min-height: var(--target);
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
  }

  .brand-mark {
    display: inline-grid;
    width: var(--target);
    height: var(--target);
    place-items: center;
    border: var(--border-strong) solid var(--ink);
    border-radius: var(--radius);
    font-family: var(--font-mark);
    font-size: var(--text-label);
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .brand-copy {
    display: flex;
    flex-direction: column;
    font-size: var(--text-micro);
    line-height: 1.25;
  }

  .brand-copy strong {
    font-weight: 600;
  }

  .brand-copy span {
    color: var(--graphite);
  }

  .site-nav,
  .site-nav__desktop,
  .site-nav__mobile-controls {
    display: flex;
    align-items: center;
  }

  .site-nav__desktop {
    gap: clamp(var(--space-3), 2.4vw, var(--space-6));
  }

  .site-nav {
    font-size: var(--text-micro);
  }

  .site-nav a,
  .menu-toggle {
    min-height: var(--target);
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }

  .site-nav a {
    position: relative;
  }

  .site-nav a::after {
    position: absolute;
    right: 0;
    bottom: var(--space-2);
    left: 0;
    height: var(--border-strong);
    background: var(--production);
    content: "";
    transform: scaleX(0);
    transform-origin: right center;
    transition: transform var(--motion-fast) var(--motion-ease);
  }

  .site-nav a:hover::after,
  .site-nav a:focus-visible::after,
  .site-nav a[aria-current="location"]::after {
    transform: scaleX(1);
    transform-origin: left center;
  }

  .site-nav a:not(.nav-cta),
  .menu-toggle {
    color: var(--graphite);
  }

  .site-nav a:not(.nav-cta):hover,
  .menu-toggle:hover {
    color: var(--ink);
  }

  .site-nav a[aria-current="location"] {
    color: var(--ink);
  }

  .nav-cta {
    gap: var(--space-2);
    color: var(--production);
    font-weight: 600;
  }

  .site-nav__mobile-controls,
  .site-nav__mobile,
  .site-nav__noscript {
    display: none;
  }

  .menu-toggle {
    gap: var(--space-2);
    padding: 0 var(--space-3);
    border: 0;
    background: transparent;
    font: inherit;
    cursor: pointer;
  }

  .menu-toggle[aria-expanded="true"] .icon-arrow {
    transform: rotate(225deg);
  }

  @media (max-width: 43.75rem) {
    .brand-copy,
    .site-nav__desktop {
      display: none;
    }

    .site-nav {
      margin-left: auto;
    }

    .site-nav__mobile-controls {
      display: flex;
      gap: var(--space-3);
    }

    .site-nav__mobile,
    .site-nav__noscript {
      position: absolute;
      z-index: 2;
      top: calc(100% + var(--border));
      right: 0;
      width: min(18rem, calc(100vw - (2 * var(--gutter))));
      padding: var(--space-3);
      border: var(--border) solid var(--line-strong);
      border-radius: var(--radius);
      background: var(--paper-raised);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--line);
    }

    .site-nav__mobile:not([hidden]) {
      display: grid;
    }

    .site-nav__noscript {
      display: grid;
    }

    .site-nav__mobile a,
    .site-nav__noscript a {
      padding-inline: var(--space-3);
    }
  }

  @media (max-width: 23.4375rem) {
    .site-nav__mobile-controls {
      gap: var(--space-2);
    }

    .menu-toggle {
      padding-inline: var(--space-2);
    }
  }
</style>
