# Obligatoria para el dominio canónico (Netlify también expone URL automáticamente).
PUBLIC_SITE_URL=

# Solo para despliegues bajo un subdirectorio, por ejemplo GitHub Pages.
PUBLIC_BASE_PATH=/

# ── Conversión ────────────────────────────────────────────────────────────────
# URL de la agenda (Cal.com o Calendly). Sin este valor no se muestra la
# "Ruta A · agenda" y el hero cambia al CTA del formulario.
# Ejemplo: https://cal.com/felipe-pena/llamada-de-encaje
PUBLIC_CAL_URL=

# Endpoint del formulario. Vacío = POST a la raíz del sitio.
# GitHub Pages NO acepta POST: mientras el sitio viva ahí, el formulario usa la
# vía de correo como respaldo. Al desplegar en Vercel (recomendado), apunta al
# endpoint incluido: PUBLIC_FORM_ENDPOINT=/api/contact
PUBLIC_FORM_ENDPOINT=

# Correo público de contacto. Aparece en el formulario, el pie de página y la
# política de privacidad, y recibe los envíos de respaldo por mailto.
# DEMO actual en src/config.ts: ing.felipe55@outlook.com
PUBLIC_CONTACT_EMAIL=

# ── Backend del formulario en Vercel (api/contact.js) ─────────────────────────
# Estas NO llevan prefijo PUBLIC_: son secretas y solo existen en el servidor.
# Configúralas en Vercel → Project → Settings → Environment Variables.
#   RESEND_API_KEY   Clave de API de Resend (https://resend.com). Ejemplo: re_xxx
#   CONTACT_EMAIL    Correo que recibe los leads. Ejemplo: bfpc-96@hotmail.com
#   RESEND_FROM      Opcional. Remitente verificado. Por defecto onboarding@resend.dev
#                    (solo pruebas; en producción verifica tu dominio en Resend).
RESEND_API_KEY=
CONTACT_EMAIL=
RESEND_FROM=

# ── Confianza ─────────────────────────────────────────────────────────────────
# Sin este valor el enlace "Verifícalo en su LinkedIn" no se muestra.
# Ejemplo: https://www.linkedin.com/in/tu-perfil/
PUBLIC_LINKEDIN_URL=

# ── Medición ──────────────────────────────────────────────────────────────────
# Opción A: Plausible. Sin estos valores no se carga su script.
# Ejemplo: PUBLIC_PLAUSIBLE_DOMAIN=consultoria-wine.vercel.app
PUBLIC_PLAUSIBLE_DOMAIN=
PUBLIC_PLAUSIBLE_SRC=

# Opción B: Vercel Web Analytics. Pon "true" SOLO en despliegues de Vercel y
# habilita Analytics en el dashboard del proyecto (Analytics → Enable).
# Los eventos del embudo (CTA Click, Form Start, Form Submit…) se duplican ahí.
PUBLIC_VERCEL_ANALYTICS=

# Opcional: retrato alternativo.
PUBLIC_PORTRAIT_PATH=
