---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "./SiteHeader.astro";
import HeroGraph from "./HeroGraph.astro";
import ProcessArtifact from "./ProcessArtifact.astro";
import ScrollThread from "./ScrollThread.astro";
import ContactPanel from "./ContactPanel.astro";
import LineIcon from "./LineIcon.astro";
import CountryFlag from "./CountryFlag.astro";
import { siteConfig, withBasePath } from "../config";
import { getCopy, type Language } from "../i18n/copy";

interface Props {
  lang?: Language;
}

const { lang = "es" } = Astro.props;
const t = getCopy(lang);
const {
  symptoms,
  offers,
  proofRows,
  phases,
} = t.landing;
const hasBooking = Boolean(siteConfig.bookingUrl);
const aiIcons = ["chat", "support", "knowledge", "automation"];
const industryIcons = ["food", "lab", "health", "factory", "transport", "finance", "construction", "government"];
const countryFlagCodes = ["CO", "MX", "PE"] as const;
const diagnosisCurrency = t.landing.services.diagnosisCurrency;
---

<BaseLayout
  lang={lang}
  title={t.seo.title}
  description={t.seo.description}
  canonicalPath={lang === "en" ? "/en/" : "/"}
  pageHomePath={lang === "en" ? "/en/" : "/"}
>
  <SiteHeader lang={lang} />
  <ScrollThread />

  <main id="contenido">
    <section class="hero" aria-labelledby="hero-title">
      <div class="container hero-grid">
        <div class="hero-copy" data-hero-sequence>
          <h1 id="hero-title" aria-label={t.landing.hero.title}>
            <span class="hero-title__clip" aria-hidden="true"><span class="hero-title__line" style="--hero-line-delay: 70ms">{t.landing.hero.titleLine1}</span></span>
            <span class="hero-title__clip" aria-hidden="true"><span class="hero-title__line" style="--hero-line-delay: 130ms">{t.landing.hero.titleLine2}</span></span>
          </h1>
          <p class="lead">{t.landing.hero.lead}</p>

          <div class="hero-action">
            <a class="button" href="#contacto" data-track="cta" data-location="hero" data-hero-item style="--hero-delay: 210ms">
              {hasBooking ? t.landing.hero.bookingCta : t.landing.hero.formCta} <span class="icon-arrow icon-arrow--down" aria-hidden="true"></span>
            </a>
            <p class="microcopy" data-hero-item style="--hero-delay: 280ms">
              {hasBooking ? t.landing.hero.bookingMicrocopy : t.landing.hero.formMicrocopy}
            </p>
          </div>

          <dl class="hero-facts" aria-label={t.landing.hero.factsLabel} data-hero-facts>
            <div><dt>{t.landing.hero.timeline}</dt><dd>{t.landing.hero.timelineValue}</dd></div>
            <div><dt>{t.landing.hero.model}</dt><dd>{t.landing.hero.modelValue}</dd></div>
            <div><dt>{t.landing.hero.ownership}</dt><dd>{t.landing.hero.ownershipValue}</dd></div>
          </dl>
        </div>

        <div class="hero-visual">
          <div class="hero-visual__status" data-hero-item style="--hero-delay: 320ms">
            <span class="label">{t.landing.hero.visualLabel}</span>
          </div>
          <HeroGraph lang={lang} />
        </div>
      </div>
    </section>

    <section class="section section-rule problem" id="problema" aria-labelledby="problem-title" data-scroll-section>
      <div class="container">
          <div class="reading-column">
            <div data-animate="heading" data-stagger="60">
              <h2 id="problem-title" data-animate-item>{t.landing.problem.title}</h2>
          </div>
          <ul class="symptom-log" data-animate="problem" data-stagger="70" data-mobile-reveal="items">
            {symptoms.map((symptom) => (
              <li data-animate-item><span aria-hidden="true"></span>{symptom}</li>
            ))}
          </ul>
          <p class="problem-thesis" data-animate="fade-up" data-delay="120">{t.landing.problem.thesis}</p>
        </div>
      </div>
    </section>

    <section class="section section-rule thesis" aria-labelledby="thesis-title" data-scroll-section>
      <div class="container">
        <div class="section-heading" data-animate="heading" data-stagger="60">
          <h2 id="thesis-title" data-animate-item>{t.landing.positioning.title}</h2>
          <p class="lead" data-animate-item>{t.landing.positioning.lead}</p>
        </div>

        <div class="positioning-axis" data-animate="comparison" data-stagger="70" data-mobile-reveal="items">
          <article class="positioning-node positioning-node--edge" data-animate-item>
            <p class="label">{t.landing.positioning.independentLabel}</p>
            <h3>{t.landing.positioning.independentTitle}</h3>
            <p>{t.landing.positioning.independentCopy}</p>
          </article>
          <span class="axis-line" aria-hidden="true"></span>
          <article class="positioning-node positioning-node--core" data-animate-item data-emphasis="core">
            <p class="label">{t.landing.positioning.hereLabel}</p>
            <h3>{t.landing.positioning.hereTitle}</h3>
            <p>{t.landing.positioning.hereCopy}</p>
          </article>
          <span class="axis-line" aria-hidden="true"></span>
          <article class="positioning-node positioning-node--edge" data-animate-item>
            <p class="label">{t.landing.positioning.agencyLabel}</p>
            <h3>{t.landing.positioning.agencyTitle}</h3>
            <p>{t.landing.positioning.agencyCopy}</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section section-rule services" id="servicios" aria-labelledby="services-title" data-scroll-section>
      <div class="container">
        <div class="section-heading section-heading--split" data-animate="heading" data-stagger="70">
          <h2 id="services-title" data-animate-item>{t.landing.services.title}</h2>
          <p class="lead" data-animate-item>{t.landing.services.lead}</p>
        </div>

        <div class="offer-pipeline" data-animate="offer-flow" data-stagger="110" data-mobile-reveal="items">
          {offers.map((offer, index) => (
            <>
              <article class:list={["offer-card", offer.core && "offer-card--core"]} data-animate-item data-emphasis={offer.core ? "core-offer" : undefined}>
                {offer.core && <span class="offer-card__core label">{t.landing.services.principal}</span>}
                <p
                  class="offer-card__meta data"
                  data-currency-value={index === 0 ? "" : undefined}
                  data-currency-kind={index === 0 ? "card" : undefined}
                  data-base-currency={index === 0 ? "COP" : undefined}
                  data-base-min={index === 0 ? "600000" : undefined}
                  data-base-max={index === 0 ? "1000000" : undefined}
                  data-cop={index === 0 ? diagnosisCurrency.card.cop : undefined}
                  aria-live={index === 0 ? "polite" : undefined}
                >
                  {index === 0 ? diagnosisCurrency.card.cop : offer.meta}
                </p>
                <h3>{offer.title}</h3>
                <p class="offer-card__description">{offer.description}</p>
                <p class="offer-card__owner label">{t.landing.services.ownerLabel} {offer.owner}</p>
              </article>
              {index < offers.length - 1 && <span class="offer-arrow icon-arrow" data-offer-arrow aria-hidden="true"></span>}
            </>
          ))}
        </div>
        <p class="currency-reference">
          {diagnosisCurrency.rateNote}{" "}
          <a href="https://www.exchangerate-api.com" rel="external noopener" data-rate-attribution>ExchangeRate API</a>
        </p>
      </div>
    </section>

    <section class="section section-rule ai-integration" id="integracion-ia" aria-labelledby="ai-title" data-scroll-section>
      <div class="container">
        <div class="section-heading section-heading--split" data-animate="heading" data-stagger="70">
          <h2 id="ai-title" data-animate-item>{t.landing.ai.title}</h2>
          <p class="lead" data-animate-item>{t.landing.ai.lead}</p>
        </div>

        <div class="ai-grid" data-animate="fade-up" data-stagger="80" data-mobile-reveal="items">
          {t.landing.ai.items.map((item, index) => (
            <article class="ai-card" data-animate-item>
              <div class="ai-card__top">
                <span class="ai-card__icon"><LineIcon name={aiIcons[index]} /></span>
                <span class="ai-card__index data" aria-hidden="true">{String(index + 1).padStart(2, "0")}</span>
              </div>
              <h3>{item.title}</h3>
              <p>{item.copy}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-rule industries" id="industrias" aria-labelledby="industries-title" data-scroll-section>
      <div class="container">
        <div class="section-heading section-heading--split" data-animate="heading" data-stagger="70">
          <h2 id="industries-title" data-animate-item>{t.landing.industries.title}</h2>
          <p class="lead" data-animate-item>{t.landing.industries.lead}</p>
        </div>

        <div class="industries-layout">
          <ul class="industry-grid" data-animate="fade-up" data-stagger="60" data-mobile-reveal="items">
            {t.landing.industries.items.map((item, index) => (
              <li data-animate-item><span class="industry-icon"><LineIcon name={industryIcons[index]} /></span>{item}</li>
            ))}
          </ul>
          <aside class="country-panel" data-animate="fade-up" data-delay="160" aria-label={t.landing.industries.countriesLabel}>
            <p>{t.landing.industries.countriesCopy}</p>
            <ul>
              {t.landing.industries.countries.map((country, index) => (
                <li><CountryFlag code={countryFlagCodes[index]} />{country}</li>
              ))}
            </ul>
          </aside>
        </div>

        <div class="vignette-list" data-animate="fade-up" data-delay="120">
          <p class="label">{t.landing.industries.vignettesLabel}</p>
          <ul>
            {t.landing.industries.vignettes.map((vignette) => (
              <li>
                <span class="vignette-sector data">{vignette.sector}</span>
                <span>{vignette.line}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section
      class="section proof"
      id="prueba"
      aria-labelledby="proof-title"
      data-proof-section
      data-track-view="Proof Viewed"
      data-track-section="compromisos-verificables"
      data-scroll-section
    >
      <div class="container">
        <div class="section-heading section-heading--split" data-animate="heading" data-stagger="70">
          <h2 id="proof-title" data-animate-item>{t.landing.proof.title}</h2>
          <p class="lead" data-animate-item>{t.landing.proof.lead}</p>
        </div>

        <div class="proof-artifact" data-animate="diff" data-stagger="70" data-mobile-reveal="items">
          <div class="proof-artifact__head label">
            <span>{t.landing.proof.signal}</span><span>{t.landing.proof.verification}</span><span>{t.landing.proof.change}</span>
          </div>
          {proofRows.map((row) => (
            <article class="proof-row" data-animate-item>
              <h3>{row.label}</h3>
              <p>{row.copy}</p>
              <div class="proof-diff">
                <div class="diff-line diff-line--old">
                  <span class="diff-marker" aria-hidden="true">{t.landing.proof.beforeMarker}</span>
                  <span class="sr-only">{t.landing.proof.before} </span>
                  <del class="proof-before data">{row.before}</del>
                </div>
                <div class="diff-line diff-line--new">
                  <span class="diff-marker" aria-hidden="true">{t.landing.proof.nowMarker}</span>
                  <span class="sr-only">{t.landing.proof.now} </span>
                  <ins class="proof-after data">{row.after}</ins>
                </div>
                <small class="label">{row.stack}</small>
              </div>
            </article>
          ))}
        </div>

        <div class="cta-band" data-animate="fade-up" data-delay="120">
          <div>
            <h3>{t.landing.ctaBand.title}</h3>
            <p class="microcopy">{t.landing.ctaBand.copy}</p>
          </div>
          <a class="button" href="#contacto" data-track="cta" data-location="mid-page">
            {t.landing.ctaBand.cta} <span class="icon-arrow icon-arrow--down" aria-hidden="true"></span>
          </a>
        </div>
      </div>
    </section>

    <section class="section section-rule process" id="proceso" aria-labelledby="process-title" data-scroll-section>
      <div class="container">
        <div class="section-heading section-heading--split" data-animate="heading" data-stagger="70">
          <h2 id="process-title" data-animate-item>{t.landing.process.title}</h2>
          <p class="lead" data-animate-item>{t.landing.process.lead}</p>
        </div>

        <ol class="phase-list" data-animate="process" data-stagger="90" data-mobile-reveal="items">
          {phases.map((phase) => (
            <li data-animate-item>
              <span class="phase-number data" data-process-badge>{phase.number}</span>
              <div>
                <p class="label">{phase.timing}</p>
                <h3>{phase.title}</h3>
                <p>{phase.copy}</p>
              </div>
            </li>
          ))}
        </ol>

        <ProcessArtifact lang={lang} />
      </div>
    </section>

    <section class="section section-rule about" id="quien" aria-labelledby="about-title" data-scroll-section>
      <div class="container about-grid" data-animate="assembly" data-stagger="100" data-mobile-reveal="items">
        <div class="identity-panel" data-animate-item>
          <picture>
            {siteConfig.portraitAvifPath && <source srcset={siteConfig.portraitAvifPath} type="image/avif" />}
            <img
              src={siteConfig.portraitPath}
              width="720"
              height="900"
              loading="lazy"
              decoding="async"
              fetchpriority="low"
              alt={t.landing.about.portraitAlt}
            />
          </picture>
          <p class="label">{t.landing.about.role}</p>
        </div>

        <div class="about-copy" data-animate-item>
          <h2 id="about-title">{t.landing.about.title}</h2>
          <p class="lead">{t.landing.about.lead}</p>
          <p>{t.landing.about.copy}</p>
          {siteConfig.linkedInUrl && (
            <a class="text-link" href={siteConfig.linkedInUrl} rel="me external">{t.landing.about.linkedIn} <span class="icon-arrow icon-arrow--up" aria-hidden="true"></span></a>
          )}
        </div>

        <aside class="capacity-panel" aria-label={t.landing.about.capacityLabel} data-animate-item>
          <p class="label">{t.landing.about.capacityTitle}</p>
          <ul>
            {t.landing.about.capacityItems.map((item) => <li><span aria-hidden="true"></span>{item}</li>)}
          </ul>
        </aside>
      </div>
    </section>

    <section class="section section-rule faq" id="preguntas" aria-labelledby="faq-title" data-scroll-section>
      <div class="container">
        <div class="section-heading" data-animate="heading" data-stagger="60">
          <h2 id="faq-title" data-animate-item>{t.landing.faq.title}</h2>
        </div>
        <dl class="faq-grid" data-faq data-animate="faq-list" data-stagger="55" data-mobile-reveal="items">
          {t.landing.faq.items.map((faq, index) => (
            <div class="faq-item is-open" data-faq-item data-animate-item>
              <dt>
                <button
                  type="button"
                  id={`faq-question-${index + 1}`}
                  aria-expanded="true"
                  aria-controls={`faq-answer-${index + 1}`}
                  data-faq-toggle
                >
                  <span>{faq.question}</span>
                  <span class="faq-icon" aria-hidden="true"><span class="faq-icon__bar"></span><span class="faq-icon__bar faq-icon__bar--vertical"></span></span>
                </button>
              </dt>
              <dd
                id={`faq-answer-${index + 1}`}
                role="region"
                aria-labelledby={`faq-question-${index + 1}`}
                aria-hidden="false"
                data-faq-panel
              >
                <div>
                  {"currencyPrice" in faq ? (
                    <p>
                      {faq.answerBefore}<span
                        class="diagnosis-price-inline"
                        data-currency-value
                        data-currency-kind="sentence"
                        data-base-currency="COP"
                        data-base-min="600000"
                        data-base-max="1000000"
                        data-cop={diagnosisCurrency.sentence.cop}
                      >{diagnosisCurrency.sentence.cop}</span>{faq.answerAfter}
                    </p>
                  ) : (
                    <p>{faq.answer}</p>
                  )}
                </div>
              </dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <ContactPanel lang={lang} />
  </main>

  <footer class="site-footer" data-scroll-section>
    <div class="container footer-grid" data-animate="footer" data-stagger="60">
      <div class="footer-brand" data-animate-item>
        <span class="footer-mark" aria-hidden="true">FP</span>
        <p>
          <strong>Felipe Peña</strong><br />{t.landing.footer.description}<br />
          <span class="footer-location">{t.landing.footer.location}</span>
        </p>
      </div>
      <div class="footer-meta" data-animate-item>
        {siteConfig.email && <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>}
        {siteConfig.linkedInUrl && (
          <a href={siteConfig.linkedInUrl} rel="me external">LinkedIn <span class="icon-arrow icon-arrow--up" aria-hidden="true"></span></a>
        )}
        <a href={withBasePath(lang === "en" ? "/en/privacy/" : "/privacidad/")}>{t.landing.footer.privacy}</a>
      </div>
    </div>
  </footer>

</BaseLayout>

<style>
  .hero {
    min-height: calc(45rem - var(--header-height));
    display: grid;
    align-items: center;
    padding-block: clamp(var(--space-7), 7vh, var(--space-9));
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(23rem, 0.9fr);
    gap: clamp(var(--space-7), 6vw, var(--space-9));
    align-items: center;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    font-family: var(--font-body-fallback);
  }

  .hero-copy .lead {
    margin-top: var(--space-5);
  }

  .hero-copy h1 {
    font-family: var(--font-display-fallback);
  }

  .hero-copy h1::after {
    width: clamp(var(--space-8), 9vw, var(--space-10));
    height: var(--border-strong);
    display: block;
    margin-top: var(--space-4);
    background: var(--production);
    content: "";
    transform-origin: left center;
  }

  .hero-title__clip {
    display: block;
  }

  .hero-title__line {
    display: block;
  }

  /* El lead queda estático porque Chrome lo identifica como LCP; los demás elementos conservan el stagger de 70 ms. */
  @media (prefers-reduced-motion: no-preference) {
    [data-hero-item] {
      animation: hero-enter var(--motion-duration) var(--motion-ease) both;
      animation-delay: var(--hero-delay);
    }

    [data-hero-facts]::before {
      animation: hero-rule var(--motion-slow) var(--motion-ease) 330ms both;
    }

    [data-hero-facts] > div {
      animation: hero-fact var(--motion-duration) var(--motion-ease) both;
    }

    [data-hero-facts] > div:nth-child(1) { animation-delay: 390ms; }
    [data-hero-facts] > div:nth-child(2) { animation-delay: 445ms; }
    [data-hero-facts] > div:nth-child(3) { animation-delay: 500ms; }
  }

  @media (min-width: 56.3125rem) and (prefers-reduced-motion: no-preference) {
    .hero-title__line {
      animation: hero-title-line var(--motion-slow) var(--motion-ease) both;
      animation-delay: var(--hero-line-delay);
    }

    .hero-copy h1::after {
      animation: hero-rule var(--motion-slow) var(--motion-ease) 220ms both;
    }
  }

  @keyframes hero-enter {
    from {
      opacity: 0.01;
      transform: translateY(var(--motion-distance));
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes hero-fade {
    from { opacity: 0.01; }
    to { opacity: 1; }
  }

  @keyframes hero-title-line {
    from { transform: translateY(var(--motion-distance)); }
    to { transform: translateY(0); }
  }

  @keyframes hero-rule {
    from { opacity: 0.2; transform: scaleX(0); }
    to { opacity: 1; transform: scaleX(1); }
  }

  @keyframes hero-fact {
    from { opacity: 0.01; transform: translateY(var(--space-2)); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-action {
    display: grid;
    grid-template-columns: auto minmax(13rem, 1fr);
    gap: var(--space-4);
    align-items: center;
    margin-top: var(--space-6);
  }

  .hero-action .microcopy {
    max-width: 29ch;
  }

  .hero-facts {
    position: relative;
    width: 100%;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    margin-top: var(--space-7);
    padding-top: var(--space-4);
  }

  .hero-facts::before {
    position: absolute;
    top: 0;
    right: 0;
    left: 0;
    height: var(--border);
    background: var(--line);
    content: "";
    transform-origin: left center;
  }

  .hero-facts dt,
  .hero-facts dd {
    font-family: var(--font-body-fallback);
    font-variant-numeric: tabular-nums;
  }

  .hero-facts dt {
    color: var(--graphite);
    font-size: var(--text-label);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .hero-facts dd {
    margin-top: var(--space-1);
    font-size: var(--text-micro);
    font-weight: 600;
  }

  .hero-visual {
    align-self: center;
  }

  .hero-visual__status {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .hero-visual__status > .label {
    color: var(--graphite);
  }

  @media (hover: hover) and (prefers-reduced-motion: no-preference) {
    .hero-action .button .icon-arrow {
      transition: transform var(--motion-fast) var(--motion-ease);
    }

    .hero-action .button:hover .icon-arrow,
    .hero-action .button:focus-visible .icon-arrow {
      transform: translate(2px, 2px) rotate(var(--arrow-rotation));
    }
  }

  .problem h2,
  .section-heading h2 {
    margin-top: var(--space-4);
  }

  .symptom-log {
    display: grid;
    gap: 0;
    padding: 0;
    margin: var(--space-7) 0 0;
    border-top: var(--border) solid var(--line);
    list-style: none;
  }

  .symptom-log li {
    position: relative;
    display: grid;
    grid-template-columns: var(--space-3) 1fr;
    gap: var(--space-4);
    align-items: start;
    padding-block: var(--space-4);
  }

  .symptom-log li::after {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: var(--border);
    background: var(--line);
    content: "";
    transform-origin: left center;
  }

  .symptom-log li > span {
    width: var(--space-2);
    height: var(--space-2);
    margin-top: 0.62em;
    border-radius: var(--radius-round);
    background: var(--manual);
  }

  .problem-thesis {
    max-width: 58ch;
    margin-top: var(--space-6);
    color: var(--ink);
    font-family: var(--font-display);
    font-size: var(--text-statement);
    font-stretch: 108%;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .section-heading {
