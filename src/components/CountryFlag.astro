---
// Banderas nacionales en SVG en línea: sin peticiones externas (respeta la CSP)
// y nítidas a cualquier tamaño. Son decorativas: el nombre del país va al lado,
// así que el SVG se marca aria-hidden. Cada flag usa un clipPath con id propio
// para redondear las esquinas sin que varias banderas colisionen entre sí.
interface Props {
  code: "CO" | "MX" | "PE";
}
const { code } = Astro.props;
const clip = `flag-clip-${code.toLowerCase()}`;
---

{code === "CO" && (
  <svg class="country-flag" viewBox="0 0 24 16" role="img" aria-hidden="true" focusable="false">
    <defs><clipPath id={clip}><rect width="24" height="16" rx="2.4" /></clipPath></defs>
    <g clip-path={`url(#${clip})`}>
      <rect width="24" height="16" fill="#FCD116" />
      <rect y="8" width="24" height="4" fill="#003893" />
      <rect y="12" width="24" height="4" fill="#CE1126" />
    </g>
    <rect width="24" height="16" rx="2.4" fill="none" stroke="rgba(26,34,46,0.18)" stroke-width="1" />
  </svg>
)}

{code === "MX" && (
  <svg class="country-flag" viewBox="0 0 24 16" role="img" aria-hidden="true" focusable="false">
    <defs><clipPath id={clip}><rect width="24" height="16" rx="2.4" /></clipPath></defs>
    <g clip-path={`url(#${clip})`}>
      <rect width="8" height="16" fill="#006847" />
      <rect x="8" width="8" height="16" fill="#ffffff" />
      <rect x="16" width="8" height="16" fill="#CE1126" />
      {/* Emblema simplificado: águila estilizada sobre una base de laurel. */}
      <path d="M9.7 7.9c1-.75 1.85-.5 2.3.2.45-.7 1.3-.95 2.3-.2-1 .0-1.7.35-2.3 1-.6-.65-1.3-1-2.3-1z" fill="#6b4e2e" />
      <path d="M10 9.5c.85.7 3.15.7 4 0" fill="none" stroke="#0a7d43" stroke-width="0.7" stroke-linecap="round" />
    </g>
    <rect width="24" height="16" rx="2.4" fill="none" stroke="rgba(26,34,46,0.18)" stroke-width="1" />
  </svg>
)}

{code === "PE" && (
  <svg class="country-flag" viewBox="0 0 24 16" role="img" aria-hidden="true" focusable="false">
    <defs><clipPath id={clip}><rect width="24" height="16" rx="2.4" /></clipPath></defs>
    <g clip-path={`url(#${clip})`}>
      <rect width="24" height="16" fill="#D91023" />
      <rect x="8" width="8" height="16" fill="#ffffff" />
    </g>
    <rect width="24" height="16" rx="2.4" fill="none" stroke="rgba(26,34,46,0.18)" stroke-width="1" />
  </svg>
)}
