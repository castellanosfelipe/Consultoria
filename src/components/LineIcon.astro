const paths = icons[name] ?? icons.automation;
---

<span class="line-icon" data-line-icon={name} aria-hidden="true">
  <svg viewBox="0 0 24 24" fill="none" focusable="false">
    {paths.map((path) => (
      <path d={path} vector-effect="non-scaling-stroke"></path>
    ))}
  </svg>
</span>

<style>
  .line-icon,
  .line-icon svg {
    width: var(--icon-size, var(--space-5));
    height: var(--icon-size, var(--space-5));
    display: block;
    flex: none;
  }

  .line-icon svg {
    stroke: currentColor;
    stroke-width: 1.65;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
</style>
