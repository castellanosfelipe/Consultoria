---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import HeroGraph from "../components/HeroGraph.astro";
import ProcessArtifact from "../components/ProcessArtifact.astro";
import ContactPanel from "../components/ContactPanel.astro";
import { siteConfig } from "../config";

const symptoms = [
  "El cierre de mes tarda una semana: alguien consolida seis hojas de cálculo a mano.",
  "Tu ERP, tu CRM y tu facturación no se hablan; una persona copia datos entre ellos.",
  "Las decisiones del lunes se toman con los datos del jueves pasado.",
  "Ya lo intentaste con un freelancer y el proyecto murió cuando desapareció.",
];

const offers = [
  {
    price: "USD 1.900 · 2 semanas",
    title: "Diagnóstico técnico de operación",
    description:
      "Mapa de procesos y sistemas, arquitectura propuesta y plan con precio cerrado. El documento es tuyo aunque construyas con otro.",
    owner: "100% Felipe · se abona al proyecto",
  },
  {
    price: "Desde USD 15.000 · 8–16 semanas",
    title: "Sistema en producción",
    description:
      "Software funcionando, código y documentación de tu propiedad, handover y cuatro semanas de soporte. Precio cerrado tras diagnóstico.",
    owner: "Felipe diseña y decide · el núcleo construye",
    core: true,
  },
  {
    price: "Desde USD 2.500 / mes",
    title: "Evolución continua",
    description:
      "Mejoras, integraciones, soporte prioritario y roadmap trimestral. Solo para sistemas que construimos.",
    owner: "El equipo ejecuta · Felipe prioriza",
  },
];

const proofRows = [
  {
    label: "Alcance",
    copy: "El diagnóstico convierte una operación difusa en una propuesta con límites, responsables y decisiones explícitas.",
    before: "estimación abierta",
    after: "precio + plazo cerrado",
    stack: "MAPA · ARQUITECTURA · PROPUESTA",
  },
  {
    label: "Avance",
    copy: "No esperas hasta la entrega para descubrir qué se construyó: ves el producto funcionando desde la primera o segunda semana.",
    before: "status report",
    after: "software cada viernes",
    stack: "DEMO · TABLERO · STAGING",
  },
  {
    label: "Propiedad",
    copy: "La continuidad no depende de una caja negra: repositorios, accesos, documentación y contexto viven contigo desde el inicio.",
    before: "dependencia",
    after: "código tuyo, día 1",
    stack: "REPO · DOCS · HANDOVER",
  },
];

const phases = [
  {
    number: "01",
    title: "Diagnóstico",
    timing: "2 semanas",
    copy: "Entrevistas, mapa de sistemas y plan con precio cerrado.",
  },
  {
    number: "02",
    title: "Primer demo",
    timing: "semana 1–2",
    copy: "Demo navegable. Desde aquí, software cada viernes; no diapositivas.",
  },
  {
    number: "03",
    title: "Cada semana",
    timing: "ritmo visible",
    copy: "Demo de avance, tablero compartido y staging abierto.",
  },
  {
    number: "04",
    title: "Entrega",
    timing: "producción",
    copy: "Código, docs, handover y cuatro semanas de soporte.",
  },
];

const exclusions = [
  "apps móviles de consumo",
  "sitios web de marketing",
  "staff augmentation",
  "rescates de código ajeno sin diagnóstico",
  "proyectos sin un dueño del lado del cliente",
];

const faqs = [
  {
    question: "¿Cuánto cuesta?",
    answer:
      "El diagnóstico cuesta USD 1.900. Los proyectos suelen estar entre USD 15.000 y 50.000, con precio cerrado después del diagnóstico. Si tu presupuesto está por debajo, te lo diré en la primera llamada.",
  },
  {
    question: "¿Quién hace realmente el trabajo?",
    answer:
      "Diseño, decisiones y gestión: yo. El código lo escribimos el equipo y yo según el módulo; todo pasa por mi revisión.",
  },
  {
    question: "¿Cuánto se demora?",
    answer:
      "Normalmente 8–16 semanas. El plazo se compromete en la propuesta; no se deja como una estimación abierta.",
  },
  {
    question: "¿Voy a terminar hablando con un junior?",
    answer:
      "No. Tu interlocutor soy yo, siempre. No hay account manager ni teléfono roto entre quien entiende y quien decide.",
  },
  {
    question: "¿De quién es el código?",
    answer:
      "Tuyo. Repositorios, documentación y accesos están a tu nombre desde el día uno.",
  },
  {
    question: "¿Qué tan grande es el equipo?",
    answer:
      "Depende del alcance. En tu propuesta aparecen el nombre, el rol y el momento de entrada de cada persona; nunca una capacidad anónima.",
  },
  {
    question: "¿Qué pasa si alguien desaparece?",
    answer:
      "Tablero, documentación y al menos otra persona con contexto reducen esa dependencia. Yo sigo siendo responsable contractual de la entrega.",
  },
  {
    question: "¿Trabajan con cualquier empresa?",
    answer:
      "No. Encaja mejor una operación B2B con un proceso crítico, un dueño interno y presupuesto para resolverlo de punta a punta.",
  },
];

const hasBooking = Boolean(siteConfig.bookingUrl);
---

<BaseLayout>
  <SiteHeader />

  <main id="contenido">
    <section class="hero" aria-labelledby="hero-title">
      <div class="container hero-grid">
        <div class="hero-copy" data-hero-sequence>
          <p class="eyebrow" data-hero-item style="--hero-delay: 0ms">Software interno · automatización de datos</p>
          <h1 id="hero-title" data-hero-item style="--hero-delay: 70ms">Software interno al ritmo de tu operación.</h1>
          <p class="lead" data-hero-item style="--hero-delay: 140ms">
            Tu operación creció más rápido que tus sistemas. Diseño, gestiono y construyo — con mi equipo — el software y las automatizaciones que la ponen al día. En producción en 8–16 semanas, con un solo responsable de punta a punta.
          </p>

          <div class="hero-action">
            <a class="button" href="#contacto" data-track="cta" data-location="hero" data-hero-item style="--hero-delay: 210ms">
              {hasBooking ? "Reservar llamada de encaje" : "Contarme tu proceso"} <span class="icon-arrow icon-arrow--down" aria-hidden="true"></span>
            </a>
            <p class="microcopy" data-hero-item style="--hero-delay: 280ms">
              {hasBooking
                ? "30 minutos gratis, conmigo — no con un comercial. En 48 horas recibes una lectura y un rango."
                : "Tres campos, sin newsletter. En 48 horas recibes una lectura y un rango, o una respuesta honesta."}
            </p>
          </div>

          <dl class="hero-facts" aria-label="Condiciones principales" data-hero-item style="--hero-delay: 350ms">
            <div><dt>Plazo</dt><dd>8–16 semanas</dd></div>
            <div><dt>Modelo</dt><dd>precio cerrado</dd></div>
            <div><dt>Propiedad</dt><dd>código tuyo</dd></div>
          </dl>
        </div>

        <div class="hero-visual">
          <div class="hero-visual__status">
            <span class="label">De fragmentos a sistema</span>
          </div>
          <HeroGraph />
        </div>
      </div>
    </section>

    <section class="section section-rule problem" id="problema" aria-labelledby="problem-title">
      <div class="container">
        <div class="reading-column">
          <p class="eyebrow">Estado: manual</p>
          <h2 id="problem-title">¿Te suena?</h2>
          <ul class="symptom-log" data-animate="fade-up" data-stagger="70">
            {symptoms.map((symptom) => (
              <li data-animate-item><span aria-hidden="true"></span>{symptom}</li>
            ))}
          </ul>
          <p class="problem-thesis">
            No es un problema de tecnología. Es la brecha entre cómo creció tu negocio y los sistemas con los que lo operas. Esa brecha se paga todos los meses, en horas y en errores.
          </p>
        </div>
      </div>
    </section>

    <section class="section section-rule thesis" aria-labelledby="thesis-title">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Una categoría deliberada</p>
          <h2 id="thesis-title">La estructura justa, sin teléfono roto.</h2>
          <p class="lead">Tratas con quien entiende, diseña y decide; respaldado por capacidad real para construir.</p>
        </div>

        <div class="positioning-axis" data-animate="fade-up" data-stagger="70">
          <article class="positioning-node positioning-node--edge" data-animate-item>
            <p class="label">Freelancer</p>
            <h3>Directo, pero frágil</h3>
            <p>Económico; si se cae esa persona, también se cae tu proyecto.</p>
          </article>
          <span class="axis-line" aria-hidden="true"></span>
          <article class="positioning-node positioning-node--core" data-animate-item data-emphasis="core" data-delay="200">
            <p class="label">Aquí · lo del medio</p>
            <h3>Responsable + equipo</h3>
            <p>Yo diseño y decido; un núcleo estable construye. Gestión y producto viven en la misma cabeza.</p>
          </article>
          <span class="axis-line" aria-hidden="true"></span>
          <article class="positioning-node positioning-node--edge" data-animate-item>
            <p class="label">Agencia</p>
            <h3>Estructura, pero distancia</h3>
            <p>Hablas con un comercial; construye alguien que no conoció tu problema.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section section-rule services" id="servicios" aria-labelledby="services-title">
      <div class="container">
        <div class="section-heading section-heading--split">
          <div>
            <p class="eyebrow">Oferta · precio visible</p>
            <h2 id="services-title">De entender la operación a ponerla en producción.</h2>
          </div>
          <p class="lead">Tres etapas conectadas. Puedes salir con el diagnóstico o continuar con un alcance y un precio que ya entiendes.</p>
        </div>

        <div class="offer-pipeline" data-animate="fade-up" data-stagger="70">
          {offers.map((offer, index) => (
            <>
              <article class:list={["offer-card", offer.core && "offer-card--core"]} data-animate-item data-emphasis={offer.core ? "core-offer" : undefined}>
                {offer.core && <span class="offer-card__core label">Core</span>}
                <p class="offer-card__price data">{offer.price}</p>
                <h3>{offer.title}</h3>
                <p class="offer-card__description">{offer.description}</p>
                <p class="offer-card__owner label">Quién: {offer.owner}</p>
              </article>
              {index < offers.length - 1 && <span class="offer-arrow icon-arrow" aria-hidden="true"></span>}
            </>
          ))}
        </div>
      </div>
    </section>

    <section
      class="section proof"
      id="prueba"
      aria-labelledby="proof-title"
      data-proof-section
      data-track-view="Proof Viewed"
      data-track-section="compromisos-verificables"
    >
      <div class="container">
        <div class="section-heading section-heading--split">
          <div>
            <p class="eyebrow">Compromisos verificables</p>
            <h2 id="proof-title">Compromisos que puedes verificar antes de la entrega.</h2>
          </div>
          <p class="lead">Sin métricas anónimas ni cifras sin contexto. Estas tres condiciones quedan visibles desde el inicio.</p>
        </div>

        <div class="proof-artifact" data-animate="diff" data-stagger="70">
          <div class="proof-artifact__head label" aria-hidden="true">
            <span>Señal</span><span>Cómo se comprueba</span><span>Diff de estado</span>
          </div>
          {proofRows.map((row) => (
            <article class="proof-row" data-animate-item>
              <h3>{row.label}</h3>
              <p>{row.copy}</p>
              <div class="proof-diff">
                <div class="diff-line diff-line--old">
                  <span class="diff-marker" aria-hidden="true">-</span>
                  <span class="sr-only">Antes: </span>
                  <del class="proof-before data">{row.before}</del>
                </div>
                <div class="diff-line diff-line--new">
                  <span class="diff-marker" aria-hidden="true">+</span>
                  <span class="sr-only">Después: </span>
                  <ins class="proof-after data">{row.after}</ins>
                </div>
                <small class="label">{row.stack}</small>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-rule process" id="proceso" aria-labelledby="process-title">
      <div class="container">
        <div class="section-heading section-heading--split">
          <div>
            <p class="eyebrow">Cómo trabajo</p>
            <h2 id="process-title">Sabrás dónde está tu proyecto cada semana.</h2>
          </div>
          <p class="lead">La secuencia no termina en una presentación: llega a producción, propiedad y handover.</p>
        </div>

        <ol class="phase-list" data-animate="process" data-stagger="90">
          {phases.map((phase) => (
            <li data-animate-item>
              <span class="phase-number data" data-process-badge>{phase.number}</span>
              <div>
                <p class="label">{phase.timing}</p>
                <h3>{phase.title}</h3>
                <p>{phase.copy}</p>
              </div>
            </li>
          ))}
        </ol>

        <ProcessArtifact />
      </div>
    </section>

    <section class="section section-rule about" id="quien" aria-labelledby="about-title">
      <div class="container about-grid">
        <div class="identity-panel">
          {siteConfig.portraitPath ? (
            <img
              src={siteConfig.portraitPath}
              width="560"
              height="700"
              loading="lazy"
              decoding="async"
              alt="Felipe Peña, product manager técnico"
            />
          ) : (
            <div class="identity-monogram" aria-hidden="true">
              <span>FP</span>
              <div class="identity-nodes"><i></i><i></i><i></i><i></i></div>
            </div>
          )}
          <p class="label">Product manager técnico · Bogotá / remoto</p>
        </div>

        <div class="about-copy">
          <p class="eyebrow">Quién responde</p>
          <h2 id="about-title">Felipe Peña, desde la primera llamada hasta la entrega.</h2>
          <p class="lead">
            Diseño la solución, gestiono el proyecto y escribo código. La persona que escucha el problema es la misma que toma decisiones y responde por el resultado.
          </p>
          <p>
            No trabajo solo — y eso es deliberado. El equipo entra como capacidad concreta, no como una caja negra.
          </p>
          {siteConfig.linkedInUrl && (
            <a class="text-link" href={siteConfig.linkedInUrl} rel="me external">Ver perfil en LinkedIn <span class="icon-arrow icon-arrow--up" aria-hidden="true"></span></a>
          )}
        </div>

        <aside class="capacity-panel" aria-label="Capacidad del equipo">
          <p class="label">La capacidad, en concreto</p>
          <ul>
            <li><span aria-hidden="true"></span> Núcleo recurrente según el alcance</li>
            <li><span aria-hidden="true"></span> Red flexible por especialidad</li>
            <li><span aria-hidden="true"></span> Conocimiento en al menos 2 personas + docs</li>
            <li><span aria-hidden="true"></span> Nombre y rol en cada propuesta</li>
          </ul>
        </aside>
      </div>
    </section>

    <section class="section section--tight section-rule exclusions" aria-labelledby="exclusions-title">
      <div class="container exclusions-grid">
        <div>
          <p class="eyebrow">Filtro publicado</p>
          <h2 id="exclusions-title">Qué no hago.</h2>
        </div>
        <div>
          <ul>
            {exclusions.map((item) => <li><span aria-hidden="true">×</span>{item}</li>)}
          </ul>
          <p class="microcopy">Si lo tuyo es esto, te lo digo en los primeros 10 minutos y te ahorro el resto.</p>
        </div>
      </div>
    </section>

    <section class="section section-rule faq" id="preguntas" aria-labelledby="faq-title">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Objeciones a la vista</p>
          <h2 id="faq-title">Preguntas directas.</h2>
        </div>
        <dl class="faq-grid" data-faq>
          {faqs.map((faq, index) => (
            <div class="faq-item is-open" data-faq-item>
              <dt>
                <button
                  type="button"
                  id={`faq-question-${index + 1}`}
                  aria-expanded="true"
                  aria-controls={`faq-answer-${index + 1}`}
                  data-faq-toggle
                >
                  <span>{faq.question}</span>
                  <span class="faq-icon" aria-hidden="true">+</span>
                </button>
              </dt>
              <dd
                id={`faq-answer-${index + 1}`}
                role="region"
                aria-labelledby={`faq-question-${index + 1}`}
                aria-hidden="false"
                data-faq-panel
              >
                <div><p>{faq.answer}</p></div>
              </dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <ContactPanel />
  </main>

  <footer class="site-footer">
    <div class="container footer-grid">
      <div class="footer-brand">
        <span class="footer-mark" aria-hidden="true">FP</span>
        <p><strong>Felipe Peña</strong><br />Software interno y automatización de datos.</p>
      </div>
      <p class="footer-stack data">PYTHON · TYPESCRIPT · SQL · KAFKA · AIRFLOW · PYSPARK · FASTAPI</p>
      <div class="footer-meta">
        {siteConfig.linkedInUrl && <a href={siteConfig.linkedInUrl} rel="me external">LinkedIn <span class="icon-arrow icon-arrow--up" aria-hidden="true"></span></a>}
        <span>Bogotá / remoto</span>
        <span>© {new Date().getFullYear()}</span>
      </div>
    </div>
  </footer>

</BaseLayout>

<style>
  .hero {
    min-height: calc(45rem - var(--header-height));
    display: grid;
    align-items: center;
    padding-block: clamp(var(--space-7), 7vh, var(--space-9));
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(23rem, 0.9fr);
    gap: clamp(var(--space-7), 6vw, var(--space-9));
    align-items: center;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    font-family: var(--font-body-fallback);
  }

  .hero-copy .eyebrow {
    margin-bottom: var(--space-5);
    font-family: var(--font-body-fallback);
  }

  .hero-copy .lead {
    margin-top: var(--space-5);
  }

  .hero-copy h1 {
    font-family: var(--font-display-fallback);
  }

  /* Entrada inmediata: el H1 empieza con CSS y nunca espera al bundle o al observer. */
  @media (prefers-reduced-motion: no-preference) {
    [data-hero-item] {
      animation: hero-enter var(--motion-duration) var(--motion-ease) both;
      animation-delay: var(--hero-delay);
    }
  }

  @keyframes hero-enter {
    from {
      opacity: 0.01;
      transform: translateY(var(--motion-distance));
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes hero-fade {
    from { opacity: 0.01; }
    to { opacity: 1; }
  }

  .hero-action {
    display: grid;
    grid-template-columns: auto minmax(13rem, 1fr);
    gap: var(--space-4);
    align-items: center;
    margin-top: var(--space-6);
  }

  .hero-action .microcopy {
    max-width: 29ch;
  }

  .hero-facts {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    margin-top: var(--space-7);
    padding-top: var(--space-4);
    border-top: var(--border) solid var(--line);
  }

  .hero-facts dt,
  .hero-facts dd {
    font-family: var(--font-body-fallback);
    font-variant-numeric: tabular-nums;
  }

  .hero-facts dt {
    color: var(--graphite);
    font-size: var(--text-label);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .hero-facts dd {
    margin-top: var(--space-1);
    font-size: var(--text-micro);
    font-weight: 600;
  }

  .hero-visual {
    align-self: center;
  }

  .hero-visual__status {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .hero-visual__status > .label {
    color: var(--graphite);
  }

  .problem h2,
  .section-heading h2 {
    margin-top: var(--space-4);
  }

  .symptom-log {
    display: grid;
    gap: 0;
    padding: 0;
    margin: var(--space-7) 0 0;
    border-top: var(--border) solid var(--line);
    list-style: none;
  }

  .symptom-log li {
    display: grid;
    grid-template-columns: var(--space-3) 1fr;
    gap: var(--space-4);
    align-items: start;
    padding-block: var(--space-4);
    border-bottom: var(--border) solid var(--line);
  }

  .symptom-log li > span {
    width: var(--space-2);
    height: var(--space-2);
    margin-top: 0.62em;
    border-radius: var(--radius-round);
    background: var(--manual);
  }

  .problem-thesis {
    max-width: 58ch;
    margin-top: var(--space-6);
    color: var(--ink);
    font-family: var(--font-display);
    font-size: var(--text-statement);
    font-stretch: 108%;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .section-heading {
    max-width: var(--reading);
    margin-bottom: var(--space-7);
  }

  .section-heading .lead {
    margin-top: var(--space-5);
  }

  .section-heading--split {
    max-width: none;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(20rem, 0.72fr);
    gap: var(--space-7);
    align-items: end;
  }

  .positioning-axis {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(var(--space-5), 0.22fr) minmax(0, 1.25fr) minmax(var(--space-5), 0.22fr) minmax(0, 1fr);
    align-items: center;
  }

  .positioning-node {
    min-height: 13rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-5);
    border-radius: var(--radius);
    background: var(--paper);
  }

  .positioning-node .label {
    margin-bottom: var(--space-4);
    color: var(--graphite);
  }

  .positioning-node p:last-child {
    margin-top: var(--space-3);
    color: var(--graphite);
    font-size: var(--text-small);
    line-height: 1.55;
  }

  .positioning-node--edge {
    border: var(--border) dashed var(--line-strong);
  }

  .positioning-node--core {
    position: relative;
    min-height: 16rem;
    border: var(--border-strong) solid var(--ink);
    box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--line);
  }

  .positioning-node--core::after {
    position: absolute;
    inset: calc(-1 * var(--border-strong));
    border: var(--border-strong) solid var(--production);
    border-radius: var(--radius);
    content: "";
    opacity: 0;
    pointer-events: none;
    transform: scaleX(0.45);
    transform-origin: left center;
  }

  @media (prefers-reduced-motion: no-preference) {
