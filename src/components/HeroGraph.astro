---
import { getCopy, type Language } from "../i18n/copy";

interface Props {
  lang?: Language;
}

const { lang = "es" } = Astro.props;
const t = getCopy(lang).graph;
---

<figure class="hero-graph" data-animate="system-graph" data-delay="260">
  <svg class="hero-graph__desktop" viewBox="0 0 600 440" aria-hidden="true">
    <rect class="frame" x="1" y="1" width="598" height="438" rx="4" />
    <text class="meta meta--before" x="28" y="38">{t.before}</text>
    <text class="meta meta--after" x="28" y="38">{t.after}</text>
    <text class="meta meta--right" x="572" y="38">{t.weeks}</text>

    <g class="source-network">
      <g class="source-routes edges">
        <path d="M190 88 C208 88 208 138 222 146" />
        <path d="M190 150 H222" />
        <path d="M190 212 C208 212 208 186 222 180" />
        <path d="M410 88 C392 88 392 138 378 146" />
        <path d="M410 150 H378" />
        <path d="M410 212 C392 212 392 186 378 180" />
      </g>

      <g class="source-node source-node--left" style="--source-delay: 0ms; --retire-x: 18px">
        <rect x="20" y="70" width="170" height="36" rx="4" />
        <circle cx="38" cy="88" r="4" />
        <text x="52" y="93">{t.monthlyClose}</text>
      </g>
      <g class="source-node source-node--left" style="--source-delay: 70ms; --retire-x: 18px">
        <rect x="20" y="132" width="170" height="36" rx="4" />
        <circle cx="38" cy="150" r="4" />
        <text x="52" y="155">{t.orders}</text>
      </g>
      <g class="source-node source-node--left" style="--source-delay: 140ms; --retire-x: 18px">
        <rect x="20" y="194" width="170" height="36" rx="4" />
        <circle cx="38" cy="212" r="4" />
        <text x="52" y="217">{t.salesReport}</text>
      </g>
      <g class="source-node source-node--right" style="--source-delay: 210ms; --retire-x: -18px">
        <rect x="410" y="70" width="170" height="36" rx="4" />
        <circle cx="428" cy="88" r="4" />
        <text x="442" y="93">ERP</text>
      </g>
      <g class="source-node source-node--right" style="--source-delay: 280ms; --retire-x: -18px">
        <rect x="410" y="132" width="170" height="36" rx="4" />
        <circle cx="428" cy="150" r="4" />
        <text x="442" y="155">CRM</text>
      </g>
      <g class="source-node source-node--right" style="--source-delay: 350ms; --retire-x: -18px">
        <rect x="410" y="194" width="170" height="36" rx="4" />
        <circle cx="428" cy="212" r="4" />
        <text x="442" y="217">{t.billing}</text>
      </g>

      <g class="manual-core">
        <rect class="manual-core__shell" x="222" y="112" width="156" height="132" rx="4" />
        <text class="manual-core__label" x="300" y="137">{t.repetitive}</text>
        <circle class="manual-core__fault" cx="300" cy="176" r="18" />
        <path class="manual-core__cross" d="M293 169 L307 183 M307 169 L293 183" />
        <text class="manual-core__copy" x="300" y="215">{t.copyReview}</text>
        <text class="manual-core__copy" x="300" y="231">{t.fixRepeat}</text>
      </g>

      <g class="manual-chip">
        <rect x="150" y="270" width="300" height="60" rx="4" />
        <circle cx="174" cy="291" r="5" />
        <text x="190" y="296">{t.monthEnd}</text>
        <text x="174" y="317">{t.sources}</text>
      </g>
    </g>

    <g class="compile-stage">
      <rect class="compile-stage__shell" x="170" y="112" width="260" height="132" rx="4" />
      <circle class="compile-stage__status" cx="194" cy="136" r="5" />
      <text class="compile-stage__command" x="210" y="141">{t.connecting}</text>
      <text class="compile-stage__copy" x="194" y="166">{t.unifying}</text>
      <g class="build-bars">
        <rect class="build-track" x="194" y="182" width="212" height="5" rx="2.5" />
        <rect class="build-fill build-fill--one" x="194" y="182" width="212" height="5" rx="2.5" />
        <rect class="build-track" x="194" y="199" width="212" height="5" rx="2.5" />
        <rect class="build-fill build-fill--two" x="194" y="199" width="212" height="5" rx="2.5" />
        <rect class="build-track" x="194" y="216" width="212" height="5" rx="2.5" />
        <rect class="build-fill build-fill--three" x="194" y="216" width="212" height="5" rx="2.5" />
      </g>
      <text class="compile-stage__meta" x="300" y="237">{t.buildMeta}</text>
    </g>

    <g class="production-network">
      <g class="production-labels">
        <text style="--delay: 0ms" x="84" y="288">{t.inputs}</text>
        <text style="--delay: 60ms" x="188" y="288">{t.validation}</text>
        <text style="--delay: 120ms" x="292" y="288">{t.flow}</text>
        <text style="--delay: 180ms" x="396" y="288">{t.alerts}</text>
        <text style="--delay: 240ms" x="500" y="288">{t.control}</text>
      </g>
      <path class="deploy-link" d="M300 218 V270" />
      <path class="pipeline" d="M70 310 H516" />
      <path class="arrow" d="M516 303 L532 310 L516 317 Z" />
      <rect class="deploy-packet deploy-packet--one" x="76" y="303" width="16" height="14" rx="3" />
      <rect class="deploy-packet deploy-packet--two" x="76" y="303" width="16" height="14" rx="3" />
      <g class="production-nodes">
        <circle style="--delay: 0ms" cx="84" cy="310" r="9" />
        <circle style="--delay: 60ms" cx="188" cy="310" r="9" />
        <circle style="--delay: 120ms" cx="292" cy="310" r="9" />
        <circle style="--delay: 180ms" cx="396" cy="310" r="9" />
        <circle style="--delay: 240ms" cx="500" cy="310" r="9" />
      </g>
      <circle class="merge-pulse" cx="500" cy="310" r="14" />
      <g class="production-chip">
        <rect x="150" y="158" width="300" height="60" rx="4" />
        <circle cx="174" cy="179" r="5" />
        <text class="terminal-line terminal-line--command" x="190" y="184">{t.connected}</text>
        <text class="terminal-line terminal-line--status" x="174" y="205">{t.status}</text>
      </g>
    </g>
  </svg>

  <svg class="hero-graph__mobile" viewBox="0 0 360 248" aria-hidden="true">
    <rect class="frame" x="1" y="1" width="358" height="246" rx="4" />
    <text class="meta mobile-before" style="--mobile-in: 350ms" x="18" y="28">{t.before}</text>

    <g class="mobile-manual">
      <text class="node-label mobile-before" style="--mobile-in: 750ms" x="18" y="62">{t.mobileSources}</text>
      <text class="node-label mobile-before" style="--mobile-in: 1.05s" x="18" y="92">ERP + CRM</text>
      <g class="edges mobile-before" style="--mobile-in: 1.35s">
        <path d="M122 57 C145 57 151 72 166 77" />
        <path d="M105 87 C132 87 147 84 166 80" />
        <path d="M194 79 H226" />
      </g>
      <g class="source-nodes mobile-before" style="--mobile-in: 1.65s">
        <circle cx="122" cy="57" r="5" />
        <circle cx="105" cy="87" r="5" />
        <circle cx="226" cy="79" r="5" />
      </g>
      <g class="broken-node mobile-before" style="--mobile-in: 1.9s">
        <circle cx="180" cy="79" r="14" />
        <path d="M174 73 L186 85 M186 73 L174 85" />
      </g>
      <text class="mobile-manual-status mobile-before" style="--mobile-in: 2.2s" x="338" y="83">{t.manual}</text>
    </g>

    <path class="mobile-transition mobile-before" style="--mobile-in: 3.45s" d="M180 112 V137 M173 130 L180 137 L187 130" />
    <text class="meta mobile-after" style="--mobile-after-in: 4.85s" x="18" y="157">{t.after}</text>
    <path class="pipeline pipeline--static mobile-after" style="--mobile-after-in: 5.25s" d="M30 190 H312" />
    <path class="arrow arrow--static mobile-after" style="--mobile-after-in: 6.35s" d="M312 183 L328 190 L312 197 Z" />
    <g class="production-nodes production-nodes--static mobile-after">
      <circle class="mobile-after" style="--mobile-after-in: 5.55s" cx="46" cy="190" r="8" />
      <circle class="mobile-after" style="--mobile-after-in: 5.75s" cx="110" cy="190" r="8" />
      <circle class="mobile-after" style="--mobile-after-in: 5.95s" cx="174" cy="190" r="8" />
      <circle class="mobile-after" style="--mobile-after-in: 6.15s" cx="238" cy="190" r="8" />
      <circle class="mobile-after" style="--mobile-after-in: 6.35s" cx="302" cy="190" r="8" />
    </g>
    <text class="mobile-status mobile-after" style="--mobile-after-in: 6.75s" x="180" y="228">{t.status}</text>
  </svg>

  <figcaption class="sr-only" id="graph-caption">{t.caption}</figcaption>
</figure>

<style>
  .hero-graph {
    width: 100%;
    margin: 0;
  }

  .hero-graph svg {
    width: 100%;
    height: auto;
  }

  .hero-graph__mobile {
    display: none;
  }

  .frame {
    fill: var(--paper-raised);
    stroke: var(--line);
    stroke-width: 2;
  }

  .meta,
  .node-label,
  .manual-chip text,
  .production-chip text,
  .mobile-status,
  .mobile-manual-status {
    font-family: var(--font-data);
  }

  .meta {
    fill: var(--graphite);
    font-size: var(--text-label);
    font-weight: 500;
    letter-spacing: 0.08em;
  }

  .meta--right,
  .node-label--right {
    text-anchor: end;
  }

  .node-label {
    fill: var(--ink);
    font-size: var(--text-label);
    font-weight: 500;
  }

  .edges path {
    fill: none;
    stroke: var(--graphite);
    stroke-width: 1.5;
  }

  .source-node rect,
  .manual-core__shell,
  .compile-stage__shell {
    fill: var(--paper-raised);
    stroke: var(--line-strong);
    stroke-width: 1.5;
  }

  .source-node circle {
    fill: var(--manual);
  }

  .source-node text,
  .manual-core text,
  .compile-stage text,
  .production-labels text {
    font-family: var(--font-data);
  }

  .source-node text {
    fill: var(--ink);
    font-size: var(--text-label);
    font-weight: 500;
  }

  .source-node,
  .source-routes,
  .manual-core,
  .manual-chip,
  .compile-stage,
  .production-chip,
  .production-labels text {
    transform-box: fill-box;
    transform-origin: center;
  }

  .manual-core__label,
  .manual-core__copy,
  .compile-stage__meta,
  .production-labels text {
    text-anchor: middle;
  }

  .manual-core__label,
  .manual-core__copy {
    fill: var(--manual);
    font-size: var(--text-tiny);
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .manual-core__fault {
    fill: var(--paper-raised);
    stroke: var(--manual);
    stroke-width: 2;
  }

  .manual-core__cross {
    stroke: var(--manual);
    stroke-linecap: round;
    stroke-width: 2.5;
  }

  .compile-stage__shell {
    stroke: var(--production);
  }

  .compile-stage__status {
    fill: var(--production);
  }

  .compile-stage__command,
  .compile-stage__copy,
  .compile-stage__meta {
    fill: var(--graphite);
    font-size: var(--text-tiny);
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .compile-stage__command {
    fill: var(--production);
    font-size: var(--text-label);
  }

  .build-track {
    fill: var(--line);
  }

  .build-fill {
    fill: var(--production);
    transform: scaleX(1);
    transform-box: fill-box;
    transform-origin: left center;
  }

  .broken-node circle {
    fill: var(--paper-raised);
    stroke: var(--manual);
    stroke-width: 2;
  }

  .broken-node path {
    stroke: var(--manual);
    stroke-linecap: round;
    stroke-width: 2.5;
  }

  .manual-chip rect {
    fill: var(--paper-raised);
    stroke: var(--manual);
  }

  .manual-chip circle {
    fill: var(--manual);
  }

  .manual-chip text {
    fill: var(--manual);
    font-size: var(--text-label);
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  .source-network,
  .compile-stage {
    opacity: 0;
  }

  .meta--before {
    opacity: 0;
  }

  .meta--after {
    opacity: 1;
  }

  .production-network {
    opacity: 1;
  }

  .pipeline {
    fill: none;
    stroke: var(--ink);
    stroke-width: 3;
    transform: scaleX(1);
    transform-box: fill-box;
    transform-origin: left center;
    vector-effect: non-scaling-stroke;
  }

  .arrow {
    fill: var(--ink);
    opacity: 1;
  }

  .production-nodes circle {
    fill: var(--production);
    opacity: 1;
    transform-box: fill-box;
    transform-origin: center;
  }

  .production-labels text {
    fill: var(--graphite);
    font-size: var(--text-tiny);
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .deploy-packet {
    fill: var(--on-production);
    stroke: var(--production);
    stroke-width: 2;
    opacity: 0;
    transform-box: fill-box;
    transform-origin: center;
  }

  .deploy-link {
    fill: none;
    stroke: var(--production);
    stroke-width: 2;
    transform: scaleY(1);
    transform-box: fill-box;
    transform-origin: top center;
    vector-effect: non-scaling-stroke;
  }

  .merge-pulse {
    fill: none;
    stroke: var(--production);
    stroke-width: 2;
    opacity: 0;
    transform-box: fill-box;
    transform-origin: center;
    vector-effect: non-scaling-stroke;
  }

  .production-chip {
    opacity: 1;
  }

  .production-chip rect {
    fill: var(--production);
  }

  .production-chip circle {
    fill: var(--on-production);
  }

  .production-chip text {
    fill: var(--on-production);
    font-size: var(--text-label);
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  .production-chip .terminal-line--status {
    font-size: var(--text-tiny);
  }

  /*
   * Cuatro actos, sin GSAP: fuentes, operación manual, build y producción.
   * El arco completo dura ~9.8 s: cada estado conserva una pausa de lectura
   * antes del siguiente cambio. El easing sigue siendo preciso, sin rebote.
  */
  @media (min-width: 56.3125rem) and (prefers-reduced-motion: no-preference) {
    .hero-graph.graph-motion-ready {
      --graph-source-in: 220ms;
      --graph-route-in: 650ms;
      --graph-manual-in: 1.1s;
      --graph-manual-terminal-in: 1.65s;
      --graph-source-out: 4.6s;
      --graph-route-out: 4.55s;
      --graph-manual-out: 4.6s;
      --graph-manual-terminal-out: 4.7s;
      --graph-build-in: 4.55s;
      --graph-build-bar-one: 5.15s;
      --graph-build-bar-two: 5.55s;
      --graph-build-bar-three: 5.95s;
      --graph-build-out: 7.75s;
      --graph-meta-out: 7.5s;
      --graph-meta-in: 7.85s;
      --graph-pipeline-in: 7.6s;
      --graph-deploy-link-in: 7.8s;
      --graph-packet-one-in: 7.85s;
      --graph-packet-two-in: 8.25s;
      --graph-production-chip-in: 7.8s;
      --graph-production-nodes-in: 8.15s;
      --graph-production-command-in: 8.2s;
      --graph-production-status-in: 8.6s;
      --graph-production-arrow-in: 8.5s;
      --graph-production-pulse-in: 8.75s;
    }

    .hero-graph.graph-motion-ready .hero-graph__desktop {
      opacity: 0;
      transform: scale(0.985);
      transform-origin: center;
    }

    .hero-graph.graph-motion-ready .source-network {
      opacity: 1;
    }

    .hero-graph.graph-motion-ready .meta--before {
      opacity: 1;
    }

    .hero-graph.graph-motion-ready .meta--after,
    .hero-graph.graph-motion-ready .compile-stage,
    .hero-graph.graph-motion-ready .arrow,
    .hero-graph.graph-motion-ready .production-labels text,
    .hero-graph.graph-motion-ready .production-nodes circle,
    .hero-graph.graph-motion-ready .production-chip,
    .hero-graph.graph-motion-ready .terminal-line,
    .hero-graph.graph-motion-ready .deploy-link,
    .hero-graph.graph-motion-ready .deploy-packet,
    .hero-graph.graph-motion-ready .merge-pulse {
      opacity: 0;
    }

    .hero-graph.graph-motion-ready .pipeline,
    .hero-graph.graph-motion-ready .build-fill {
      transform: scaleX(0);
    }

    .hero-graph.graph-motion-ready .deploy-link {
      transform: scaleY(0);
    }

    .hero-graph.graph-motion-ready.is-visible .hero-graph__desktop {
      animation: graph-stage-in 700ms var(--motion-ease)
        var(--motion-delay, 0ms) both;
    }

    .hero-graph.graph-motion-ready.is-visible .source-node {
      animation:
        source-arrive 750ms var(--motion-ease)
          calc(var(--motion-delay, 0ms) + var(--graph-source-in) + var(--source-delay)) both,
        source-retire 650ms var(--motion-ease)
          calc(var(--motion-delay, 0ms) + var(--graph-source-out) + var(--source-delay)) forwards;
    }

    .hero-graph.graph-motion-ready.is-visible .source-routes {
      animation:
        route-arrive 900ms var(--motion-ease)
          calc(var(--motion-delay, 0ms) + var(--graph-route-in)) both,
        route-retire 650ms var(--motion-ease)
          calc(var(--motion-delay, 0ms) + var(--graph-route-out)) forwards;
    }

    .hero-graph.graph-motion-ready.is-visible .manual-core {
      animation:
        core-arrive 800ms var(--motion-ease)
          calc(var(--motion-delay, 0ms) + var(--graph-manual-in)) both,
        core-retire 650ms var(--motion-ease)
          calc(var(--motion-delay, 0ms) + var(--graph-manual-out)) forwards;
    }

    .hero-graph.graph-motion-ready.is-visible .manual-chip {
      animation:
        terminal-in 750ms var(--motion-ease)
          calc(var(--motion-delay, 0ms) + var(--graph-manual-terminal-in)) both,
        terminal-out 600ms var(--motion-ease)
          calc(var(--motion-delay, 0ms) + var(--graph-manual-terminal-out)) forwards;
    }

    .hero-graph.graph-motion-ready.is-visible .compile-stage {
      animation:
        compile-arrive 800ms var(--motion-ease)
          calc(var(--motion-delay, 0ms) + var(--graph-build-in)) both,
        compile-retire 650ms var(--motion-ease)
          calc(var(--motion-delay, 0ms) + var(--graph-build-out)) forwards;
    }

    .hero-graph.graph-motion-ready.is-visible .build-fill--one {
      animation: build-progress 700ms var(--motion-ease)
        calc(var(--motion-delay, 0ms) + var(--graph-build-bar-one)) both;
    }

    .hero-graph.graph-motion-ready.is-visible .build-fill--two {
      animation: build-progress 700ms var(--motion-ease)
        calc(var(--motion-delay, 0ms) + var(--graph-build-bar-two)) both;
    }

    .hero-graph.graph-motion-ready.is-visible .build-fill--three {
      animation: build-progress 700ms var(--motion-ease)
        calc(var(--motion-delay, 0ms) + var(--graph-build-bar-three)) both;
    }

    .hero-graph.graph-motion-ready.is-visible .pipeline {
      animation: pipeline-online 1.1s var(--motion-ease)
        calc(var(--motion-delay, 0ms) + var(--graph-pipeline-in)) both;
    }

    .hero-graph.graph-motion-ready.is-visible .deploy-link {
      animation: deploy-link-in 750ms var(--motion-ease)
        calc(var(--motion-delay, 0ms) + var(--graph-deploy-link-in)) both;
    }

    .hero-graph.graph-motion-ready.is-visible .deploy-packet--one {
      animation: packet-travel 1.35s var(--motion-ease)
        calc(var(--motion-delay, 0ms) + var(--graph-packet-one-in)) both;
    }

    .hero-graph.graph-motion-ready.is-visible .deploy-packet--two {
      animation: packet-travel 1.35s var(--motion-ease)
        calc(var(--motion-delay, 0ms) + var(--graph-packet-two-in)) both;
    }

    .hero-graph.graph-motion-ready.is-visible .arrow {
      animation: graph-fade-in 450ms var(--motion-ease)
        calc(var(--motion-delay, 0ms) + var(--graph-production-arrow-in)) both;
    }

    .hero-graph.graph-motion-ready.is-visible .production-labels text,
    .hero-graph.graph-motion-ready.is-visible .production-nodes circle {
      animation: node-online 550ms var(--motion-ease)
        calc(var(--motion-delay, 0ms) + var(--graph-production-nodes-in) + var(--delay)) both;
    }

    .hero-graph.graph-motion-ready.is-visible .production-chip {
      animation: terminal-in 800ms var(--motion-ease)
        calc(var(--motion-delay, 0ms) + var(--graph-production-chip-in)) both;
    }

    .hero-graph.graph-motion-ready.is-visible .terminal-line--command {
      animation: terminal-line-in 550ms var(--motion-ease)
        calc(var(--motion-delay, 0ms) + var(--graph-production-command-in)) both;
    }

    .hero-graph.graph-motion-ready.is-visible .terminal-line--status {
      animation: terminal-line-in 550ms var(--motion-ease)
        calc(var(--motion-delay, 0ms) + var(--graph-production-status-in)) both;
    }

    .hero-graph.graph-motion-ready.is-visible .merge-pulse {
      animation: merge-pulse 700ms var(--motion-ease)
        calc(var(--motion-delay, 0ms) + var(--graph-production-pulse-in)) both;
    }

    .hero-graph.graph-motion-ready.is-visible .meta--before {
      animation: graph-fade-out 650ms var(--motion-ease)
        calc(var(--motion-delay, 0ms) + var(--graph-meta-out)) forwards;
    }

    .hero-graph.graph-motion-ready.is-visible .meta--after {
      animation: graph-fade-in 650ms var(--motion-ease)
        calc(var(--motion-delay, 0ms) + var(--graph-meta-in)) both;
    }
  }

  .mobile-transition {
    fill: none;
    stroke: var(--graphite);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.5;
  }

  @keyframes source-arrive {
    from { opacity: 0; transform: translateY(var(--space-2)) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  @keyframes source-retire {
    from { opacity: 1; transform: translateX(0); }
    to { opacity: 0; transform: translateX(var(--retire-x)); }
  }

  @keyframes route-arrive {
    from { opacity: 0; transform: scale(0.94); }
