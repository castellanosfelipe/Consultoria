<style>
  .hero-graph {
    width: 100%;
    margin: 0;
  }

  .hero-graph svg {
    width: 100%;
    height: auto;
  }

  .hero-graph__mobile {
    display: none;
  }

  .frame {
    fill: var(--paper-raised);
    stroke: var(--line);
    stroke-width: 2;
  }

  .meta,
  .node-label,
  .manual-chip text,
  .production-chip text,
  .mobile-status,
  .mobile-manual-status {
    font-family: var(--font-data);
  }

  .meta {
    fill: var(--graphite);
    font-size: var(--text-label);
    font-weight: 500;
    letter-spacing: 0.08em;
  }

  .meta--right,
  .node-label--right {
    text-anchor: end;
  }

  .node-label {
    fill: var(--ink);
    font-size: var(--text-label);
    font-weight: 500;
  }

  .edges path {
    fill: none;
    stroke: var(--graphite);
    stroke-width: 1.5;
  }

  .fragment-node {
    fill: var(--paper-raised);
    stroke: var(--ink);
    stroke-width: 2;
  }

  .broken-node circle {
    fill: var(--paper-raised);
    stroke: var(--manual);
    stroke-width: 2;
  }

  .broken-node path {
    stroke: var(--manual);
    stroke-linecap: round;
    stroke-width: 2.5;
  }

  .manual-chip rect {
    fill: var(--paper-raised);
    stroke: var(--manual);
  }

  .manual-chip circle {
    fill: var(--manual);
  }

  .manual-chip text {
    fill: var(--manual);
    font-size: var(--text-label);
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  .manual-network {
    opacity: 0;
  }

  .meta--before {
    opacity: 0;
  }

  .meta--after {
    opacity: 1;
  }

  .pipeline {
    fill: none;
    stroke: var(--ink);
    stroke-width: 3;
    transform: scaleX(1);
    transform-box: fill-box;
    transform-origin: left center;
    vector-effect: non-scaling-stroke;
  }

  .arrow {
    fill: var(--ink);
    opacity: 1;
  }

  .production-nodes circle {
    fill: var(--production);
    opacity: 1;
    transform-box: fill-box;
    transform-origin: center;
  }

  .production-chip {
    opacity: 1;
  }

  .production-chip rect {
    fill: var(--production);
  }

  .production-chip circle {
    fill: var(--on-production);
  }

  .production-chip text {
    fill: var(--on-production);
    font-size: var(--text-label);
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  /*
   * Tres actos, sin GSAP: fragmentos (400 ms), alineación (600 ms) y
   * deploy terminal (300–500 ms). El observer añade .is-visible una sola vez.
   */
  @media (prefers-reduced-motion: no-preference) {
    :global(.motion-ready) .hero-graph .manual-network {
      opacity: 1;
    }

    :global(.motion-ready) .hero-graph .meta--before {
      opacity: 1;
    }

    :global(.motion-ready) .hero-graph .meta--after,
    :global(.motion-ready) .hero-graph .graph-fragment,
    :global(.motion-ready) .hero-graph .manual-edges,
    :global(.motion-ready) .hero-graph .broken-node,
    :global(.motion-ready) .hero-graph .arrow,
    :global(.motion-ready) .hero-graph .production-nodes circle,
    :global(.motion-ready) .hero-graph .production-chip,
    :global(.motion-ready) .hero-graph .terminal-line {
      opacity: 0;
    }

    :global(.motion-ready) .hero-graph .pipeline {
      transform: scaleX(0);
    }

    :global(.motion-ready) .hero-graph.is-visible .graph-fragment {
      animation:
        fragment-reveal 400ms var(--motion-ease) var(--fragment-delay) both,
        fragment-retire var(--motion-fast) var(--motion-ease)
          calc(1.05s + var(--fragment-delay)) forwards;
    }

    :global(.motion-ready) .hero-graph.is-visible .graph-fragment__align {
      animation: fragment-align var(--motion-slow) var(--motion-ease)
        calc(480ms + var(--fragment-delay)) both;
    }

    :global(.motion-ready) .hero-graph.is-visible .manual-edges,
    :global(.motion-ready) .hero-graph.is-visible .broken-node {
      animation:
        graph-fade-in var(--motion-fast) var(--motion-ease) 100ms both,
        graph-fade-out var(--motion-fast) var(--motion-ease) 850ms forwards;
    }

    :global(.motion-ready) .hero-graph.is-visible .manual-chip {
      animation: terminal-out var(--motion-fast) var(--motion-ease) 1.12s forwards;
    }

    :global(.motion-ready) .hero-graph.is-visible .pipeline {
      animation: pipeline-online var(--motion-duration) var(--motion-ease) 850ms both;
    }

    :global(.motion-ready) .hero-graph.is-visible .arrow {
      animation: graph-fade-in var(--motion-fast) var(--motion-ease) 1.18s both;
    }

    :global(.motion-ready) .hero-graph.is-visible .production-nodes circle {
      animation: node-online var(--motion-fast) var(--motion-ease)
        calc(980ms + var(--delay)) both;
    }

    :global(.motion-ready) .hero-graph.is-visible .production-chip {
      animation: terminal-in 400ms var(--motion-ease) 1.18s both;
    }

    :global(.motion-ready) .hero-graph.is-visible .terminal-line--command {
      animation: terminal-line-in var(--motion-fast) var(--motion-ease) 1.28s both;
    }

    :global(.motion-ready) .hero-graph.is-visible .terminal-line--status {
      animation: terminal-line-in var(--motion-fast) var(--motion-ease) 1.43s both;
    }

    :global(.motion-ready) .hero-graph.is-visible .meta--before {
      animation: graph-fade-out var(--motion-fast) var(--motion-ease) 1s forwards;
    }

    :global(.motion-ready) .hero-graph.is-visible .meta--after {
      animation: graph-fade-in var(--motion-fast) var(--motion-ease) 1.18s both;
    }
  }

  .mobile-transition {
    fill: none;
    stroke: var(--graphite);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.5;
  }

  @keyframes fragment-reveal {
    from {
      opacity: 0;
      transform: translate(var(--drift-x), var(--drift-y));
    }
    to {
      opacity: 1;
      transform: translate(0, 0);
    }
  }

  @keyframes fragment-retire {
    from { opacity: 1; }
    to { opacity: 0; }
  }

  @keyframes fragment-align {
    from { transform: translate(0, 0); }
    to { transform: translate(var(--align-x), var(--align-y)); }
  }

  @keyframes graph-fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes graph-fade-out {
    from { opacity: 1; }
    to { opacity: 0; }
  }

  @keyframes pipeline-online {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }

  @keyframes node-online {
    0% { opacity: 0; transform: scale(0.72); }
    100% { opacity: 1; transform: scale(1); }
  }

  @keyframes terminal-out {
    to { opacity: 0; transform: translateY(calc(-1 * var(--space-2))); }
  }

  @keyframes terminal-in {
    from { opacity: 0; transform: translateY(var(--space-2)); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes terminal-line-in {
    from { opacity: 0; transform: translateY(var(--space-1)); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 56.25rem) {
    .hero-graph__desktop {
      display: none;
    }

    .hero-graph__mobile {
      display: block;
    }

    .pipeline--static {
      transform: none;
      animation: none;
    }

    .arrow--static {
      opacity: 1;
      animation: none;
    }

    .production-nodes--static circle {
      opacity: 1;
      animation: none;
    }

    .mobile-status {
      fill: var(--production);
      font-size: var(--text-label);
      font-weight: 600;
      letter-spacing: 0.05em;
      text-anchor: middle;
    }

    .mobile-manual-status {
      fill: var(--manual);
      font-size: var(--text-tiny);
      font-weight: 600;
      letter-spacing: 0.05em;
      text-anchor: end;
    }
  }

  @media (max-width: 56.25rem) and (prefers-reduced-motion: no-preference) {
    :global(.motion-ready) .hero-graph .hero-graph__mobile {
      opacity: 0;
      transition: opacity var(--motion-duration) var(--motion-ease);
    }

    :global(.motion-ready) .hero-graph.is-visible .hero-graph__mobile {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .manual-network {
      display: none;
      opacity: 0;
      animation: none;
    }

    .meta--before,
    .mobile-before {
      display: none;
      opacity: 0;
    }

    .meta--after {
      opacity: 1;
    }

    .pipeline {
      transform: none;
      animation: none;
    }

    .arrow,
    .production-nodes circle,
    .production-chip {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
