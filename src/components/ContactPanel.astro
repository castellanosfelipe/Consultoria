---
import { siteConfig, withBasePath } from "../config";
import { getCopy, type Language } from "../i18n/copy";

interface Props {
  lang?: Language;
}

const { lang = "es" } = Astro.props;
const copy = getCopy(lang);
const t = copy.contact;
const diagnosisReference = copy.landing.services.diagnosisCurrency.card.cop;
const hasBooking = Boolean(siteConfig.bookingUrl);
const formAction = withBasePath(lang === "en" ? "/en/thanks/" : "/gracias/");
const formSubmitUrl =
  siteConfig.formEndpoint || withBasePath(lang === "en" ? "/en/" : "/");
const privacyHref = withBasePath(lang === "en" ? "/en/privacy/" : "/privacidad/");
---

<section class="section contact-section" id="contacto" aria-labelledby="contact-title" data-animate="contact" data-stagger="70" data-mobile-reveal="items" data-scroll-section>
  <div class="container">
    <div class="contact-intro">
      <h2 id="contact-title" data-animate-item data-contact-intro data-motion-index="0">{t.title}</h2>
      <p class="lead" data-animate-item data-contact-intro data-motion-index="1">{t.lead}</p>
    </div>

    <ol class="next-steps" aria-label={t.whatNext} data-contact-route>
      <li data-animate-item data-contact-step data-motion-index="2"><span>01</span><strong>{hasBooking ? t.chooseRoute : t.chooseWrite}</strong><small>{hasBooking ? t.chooseBooking : t.chooseForm}</small></li>
      <li data-animate-item data-contact-step data-motion-index="3"><span>02</span><strong>{t.details}</strong><small>{t.detailsCopy}</small></li>
      <li data-animate-item data-contact-step data-motion-index="4"><span>03</span><strong>{t.call}</strong><small>{t.callCopy}</small></li>
      <li data-animate-item data-contact-step data-motion-index="5"><span>04</span><strong>{t.response}</strong><small>{t.responseCopy}</small></li>
    </ol>

    <div class:list={["contact-grid", !hasBooking && "contact-grid--single"]}>
      {hasBooking && (
        <article class="contact-card booking-card" data-animate-item data-contact-card data-contact-direction="left" data-motion-index="6">
          <div>
            <p class="label">{t.bookingRoute}</p>
            <h3>{t.bookingTitle}</h3>
            <p class="microcopy">{t.bookingCopy}</p>
          </div>
          <button
            class="button"
            type="button"
            data-booking-open
            data-booking-url={siteConfig.bookingUrl}
            data-track="cta"
            data-location="booking"
            aria-describedby="booking-status"
          >
            {t.loadBooking} <span class="icon-arrow icon-arrow--down" aria-hidden="true"></span>
          </button>
          <p class="booking-status" id="booking-status" data-booking-status role="status" aria-live="polite"></p>
          <div class="booking-frame" data-booking-frame hidden></div>
          <p class="booking-direct">
            <a href={siteConfig.bookingUrl} target="_blank" rel="external noopener" data-track="cta" data-location="booking-direct">{t.openBooking}</a>
          </p>
          <noscript>
            <a href={siteConfig.bookingUrl} target="_blank" rel="external noopener">{t.openBookingTab}</a>
          </noscript>
        </article>
      )}

      <article
        class="contact-card contact-card--form"
        data-animate-item
        data-contact-card
        data-contact-direction="right"
        data-motion-index={hasBooking ? "7" : "6"}
      >
        <div>
          <p class="label">{hasBooking ? t.formRoute : t.writeLabel}</p>
          <h3>{hasBooking ? t.formTitle : t.formTitleSolo}</h3>
          <p class="microcopy">{t.formCopy}</p>
        </div>

        <form
          class="contact-form"
          name="contacto"
          method="POST"
          action={formAction}
          data-submit-url={formSubmitUrl}
          data-contact-email={siteConfig.email}
          data-netlify="true"
          data-netlify-honeypot="bot-field"
          data-contact-form
        >
          <input type="hidden" name="form-name" value="contacto" />
          <input type="hidden" name="bot-field" />
          <input type="hidden" name="country" value="CO" data-country-field />
          <input type="hidden" name="currency" value="COP" data-currency-field />
          <input type="hidden" name="diagnosis_reference" value={diagnosisReference} data-diagnosis-reference-field />

          <label for="nombre" data-animate-item data-contact-field data-motion-index={hasBooking ? "8" : "7"}>
            <span class="field-label">{t.name}</span>
            <span class="field-control"><input id="nombre" name="nombre" type="text" autocomplete="name" required minlength="2" maxlength="80" aria-describedby="nombre-error" /></span>
            <span class="field-error" id="nombre-error" data-error-for="nombre" aria-live="polite"></span>
          </label>

          <label for="email" data-animate-item data-contact-field data-motion-index={hasBooking ? "9" : "8"}>
            <span class="field-label">{t.email}</span>
            <span class="field-control"><input id="email" name="email" type="email" autocomplete="email" inputmode="email" required maxlength="120" aria-describedby="email-error" /></span>
            <span class="field-error" id="email-error" data-error-for="email" aria-live="polite"></span>
          </label>

          <label class="contact-form__wide" for="contexto" data-animate-item data-contact-field data-motion-index={hasBooking ? "10" : "9"}>
            <span class="field-label">{t.context}</span>
            <span class="field-control">
              <input
                id="contexto"
                name="contexto"
                type="text"
                required
                minlength="12"
                maxlength="280"
                aria-describedby="contexto-error"
                placeholder={t.placeholder}
              />
            </span>
            <span class="field-error" id="contexto-error" data-error-for="contexto" aria-live="polite"></span>
          </label>

          <div class="contact-form__actions contact-form__wide" data-animate-item data-contact-field data-motion-index={hasBooking ? "11" : "10"}>
            <button class="button" type="submit" data-form-submit>{t.submit} <span class="icon-arrow" aria-hidden="true"></span></button>
            <div>
              <p>{t.responseTime} {t.privacy} <a href={privacyHref}>{t.privacyLink}</a></p>
              {siteConfig.email && (
                <p class="contact-email-alt">
                  {t.emailAlt} <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
                </p>
              )}
              <p class="form-status" data-form-status role="status" aria-live="polite"></p>
            </div>
          </div>
        </form>
      </article>
    </div>
  </div>
</section>

<style>
  .contact-section {
    border-top: var(--border-strong) solid var(--ink);
    background: var(--paper-raised);
  }

  /* Una sola secuencia: intro → ruta → cards → campos. Cada pieza dura entre 300 y 480 ms. */
  @media (prefers-reduced-motion: no-preference) {
    :global(.motion-ready) [data-animate="contact"] [data-animate-item] {
      transition:
        opacity 420ms var(--motion-ease),
        transform 460ms var(--motion-ease);
      transition-delay: var(--motion-sequence-delay, 0ms);
    }

    :global(.motion-ready) [data-animate="contact"]:not(.is-visible) [data-animate-item] {
      opacity: 0;
    }

    :global(.motion-ready) [data-animate="contact"].is-visible [data-animate-item] {
      opacity: 1;
      transform: none;
    }
  }

  @media (min-width: 56.3125rem) and (prefers-reduced-motion: no-preference) {
    :global(.motion-ready) [data-animate="contact"]:not(.is-visible) [data-contact-intro],
    :global(.motion-ready) [data-animate="contact"]:not(.is-visible) [data-contact-step],
    :global(.motion-ready) [data-animate="contact"]:not(.is-visible) [data-contact-field] {
      transform: translateY(calc(var(--space-3) + var(--space-1)));
    }

    :global(.motion-ready)
      [data-animate="contact"]:not(.is-visible)
      [data-contact-direction="left"] {
      transform: translateX(calc(-1 * var(--space-5))) scale(0.985);
    }

    :global(.motion-ready)
      [data-animate="contact"]:not(.is-visible)
      [data-contact-direction="right"] {
      transform: translateX(var(--space-5)) scale(0.985);
    }

    :global(.motion-ready) [data-animate="contact"] [data-contact-route]::after {
      transition:
        opacity 320ms var(--motion-ease),
        transform 600ms var(--motion-ease);
      transition-delay: 210ms;
    }

    :global(.motion-ready)
      [data-animate="contact"]:not(.is-visible)
      [data-contact-route]::after {
      opacity: 0;
      transform: scaleX(0);
    }

    :global(.motion-ready) [data-animate="contact"] [data-contact-step] > span {
      transition:
        opacity 300ms var(--motion-ease),
        transform 320ms var(--motion-ease);
      transition-delay: calc(var(--motion-sequence-delay, 0ms) + 90ms);
    }

    :global(.motion-ready)
      [data-animate="contact"]:not(.is-visible)
      [data-contact-step]
      > span {
      opacity: 0;
      transform: scale(0.55);
    }
  }

  .contact-intro {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(18rem, 0.75fr);
    gap: var(--space-7);
    align-items: end;
  }

  .contact-intro h2 {
    max-width: 21ch;
  }

  .next-steps {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--border);
    padding: 0;
    margin: var(--space-8) 0 var(--space-7);
    border: var(--border) solid var(--line);
    list-style: none;
  }

  .next-steps::after {
    position: absolute;
    z-index: 2;
    top: calc(-1 * var(--border));
    right: calc(-1 * var(--border));
    left: calc(-1 * var(--border));
    height: var(--border-strong);
    background: var(--production);
    content: "";
    opacity: 1;
    pointer-events: none;
    transform: scaleX(1);
    transform-origin: left center;
  }

  .next-steps li {
    min-height: 9rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-5);
    border-right: var(--border) solid var(--line);
  }

  .next-steps li:last-child {
    border-right: 0;
  }

  .next-steps span,
  .next-steps strong {
    font-family: var(--font-data);
  }

  .next-steps span {
    color: var(--ink);
    font-size: var(--text-label);
    font-weight: 600;
  }

  .next-steps strong {
    font-size: var(--text-small);
    font-weight: 600;
  }

  .next-steps small {
    color: var(--graphite);
    font-size: var(--text-micro);
    line-height: 1.45;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 0.82fr 1.18fr;
    gap: var(--space-5);
    align-items: start;
  }

  .contact-grid--single {
    grid-template-columns: minmax(0, var(--reading));
  }

  .contact-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding: clamp(var(--space-5), 4vw, var(--space-7));
    border: var(--border) solid var(--line-strong);
    border-radius: var(--radius);
    background: var(--paper);
  }

  .contact-card--form {
    overflow: hidden;
    border: var(--border-strong) solid var(--ink);
    box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--line);
  }

  .contact-card--form::after {
    position: absolute;
    z-index: 2;
    top: 0;
    right: 0;
    left: 0;
    height: var(--border-strong);
    background: var(--production);
    content: "";
    opacity: 0;
    pointer-events: none;
    transform: scaleX(0);
    transform-origin: left center;
  }

  .contact-card--form:has([data-form-submit][data-state="success"])::after {
    opacity: 1;
    transform: scaleX(1);
  }

  @media (prefers-reduced-motion: no-preference) {
    .contact-card--form::after {
      transition:
        opacity 320ms var(--motion-ease),
        transform 500ms var(--motion-ease);
    }
  }

  .contact-card .label {
    margin-bottom: var(--space-3);
    color: var(--graphite);
  }

  .contact-card h3 {
    margin-bottom: var(--space-3);
  }

  .booking-card > .button {
    align-self: flex-start;
  }

  .booking-frame {
    min-height: 42rem;
    border-top: var(--border) solid var(--line);
  }

  .booking-frame :global(iframe) {
    width: 100%;
    min-height: 42rem;
    border: 0;
    background: var(--paper-raised);
  }

  .booking-direct {
    color: var(--graphite);
    font-size: var(--text-micro);
  }

  .booking-direct a {
    min-height: var(--target);
    display: inline-flex;
    align-items: center;
    color: var(--ink);
  }

  .booking-status,
  .form-status,
  .field-error {
    min-height: var(--space-5);
    color: var(--manual);
    font-size: var(--text-micro);
    line-height: 1.45;
  }

  .contact-form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }

  .contact-form label {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .field-control {
    position: relative;
    display: block;
  }

  .field-control::after {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: var(--border-strong);
    background: var(--production);
    content: "";
    opacity: 0;
    pointer-events: none;
    transform: scaleX(0);
    transform-origin: left center;
    transition:
      opacity 300ms var(--motion-ease),
      transform 320ms var(--motion-ease);
  }

  .contact-form label:focus-within .field-control::after {
    opacity: 1;
    transform: scaleX(1);
  }

  .contact-form label:has(input[aria-invalid="true"]) .field-control::after {
    background: var(--manual);
  }

  .contact-form .field-label {
    font-family: var(--font-data);
    font-size: var(--text-label);
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .contact-form input {
    width: 100%;
    min-height: var(--target);
    border: var(--border) solid var(--line-strong);
    border-radius: var(--radius);
    background: var(--paper-raised);
    color: var(--ink);
    padding: var(--space-3) var(--space-4);
  }

  .contact-form input::placeholder {
    color: var(--ink-muted);
  }

  .contact-form input:hover {
    border-color: var(--ink);
  }

  .contact-form input[aria-invalid="true"] {
    border-color: var(--manual);
    box-shadow: 0 0 0 var(--border) var(--manual);
  }

  .contact-form button[disabled] {
    cursor: wait;
    opacity: 0.72;
  }

  .contact-form [data-form-submit] {
    position: relative;
    overflow: hidden;
    min-width: 12rem;
  }

  .contact-form [data-form-submit][data-state="loading"]::after {
    position: absolute;
    right: var(--space-4);
    width: var(--space-2);
    height: var(--space-2);
    border-radius: var(--radius);
    background: currentColor;
    content: "";
    opacity: 0;
    animation: submit-packet 560ms var(--motion-ease) 1 both;
  }

  .contact-form [data-form-submit][data-state="success"] {
    animation: submit-confirm 320ms var(--motion-ease) 1 both;
  }

  .contact-form [data-form-submit][data-state="success"]::after {
    content: "✓";
    font-family: var(--font-data);
    opacity: 1;
    animation: submit-state-in var(--motion-fast) var(--motion-ease) both;
  }

  /* Un paquete cruza el botón una vez: comunica envío sin spinner infinito. */
  @keyframes submit-packet {
    0% {
      opacity: 0;
      transform: translateX(calc(-1 * var(--space-7))) scale(0.72);
    }
    18%, 78% {
      opacity: 1;
    }
    100% {
      opacity: 0;
      transform: translateX(var(--space-3)) scale(1);
    }
  }

  @keyframes submit-confirm {
    from {
      opacity: 0.82;
      transform: scale(0.98);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes submit-state-in {
    from { opacity: 0; transform: translateY(var(--space-1)); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes submit-packet-fade {
    0%, 100% { opacity: 0; }
    35%, 70% { opacity: 1; }
  }

  @keyframes submit-confirm-fade {
    from { opacity: 0.82; }
    to { opacity: 1; }
  }

  .contact-form__wide {
    grid-column: 1 / -1;
  }

  .contact-form__actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .contact-form__actions p {
    color: var(--graphite);
    font-size: var(--text-micro);
  }

  .contact-form__actions a {
    color: var(--ink);
    text-decoration-thickness: var(--border);
    text-underline-offset: 0.2em;
  }

  .contact-email-alt {
    margin-top: var(--space-1);
  }

  .form-status a {
    color: var(--production);
    font-weight: 600;
  }

  @media (max-width: 56.25rem) {
    .contact-intro,
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .contact-intro {
      gap: var(--space-5);
    }

    .next-steps {
      grid-template-columns: 1fr 1fr;
    }

    .next-steps li:nth-child(2) {
      border-right: 0;
    }

    .next-steps li:nth-child(-n + 2) {
      border-bottom: var(--border) solid var(--line);
    }

    /* En móvil la secuencia conserva solo crossfades; no hay drift ni escalado. */
    .contact-card--form::after,
    .field-control::after {
      transform: none;
      transition-property: opacity;
    }

    .contact-form [data-form-submit][data-state="loading"]::after {
      animation-name: submit-packet-fade;
    }

    .contact-form [data-form-submit][data-state="success"],
    .contact-form [data-form-submit][data-state="success"]::after {
      animation-name: submit-confirm-fade;
    }
  }

  @media (max-width: 37.4375rem) {
    /* En móvil el formulario aparece antes que los pasos: el CTA promete
       tres campos y el visitante los encuentra sin atravesar cuatro tarjetas. */
    .contact-section .container {
      display: flex;
      flex-direction: column;
    }

    .contact-intro {
      order: 1;
    }

    .contact-grid {
      order: 2;
      margin-top: var(--space-7);
    }

    .next-steps {
      order: 3;
      margin: var(--space-7) 0 0;
    }

    .next-steps,
    .contact-form {
      grid-template-columns: 1fr;
    }

    .next-steps li {
      min-height: auto;
      border-right: 0;
      border-bottom: var(--border) solid var(--line);
    }

    .next-steps li:last-child {
      border-bottom: 0;
    }

    .contact-form__wide {
      grid-column: auto;
    }

    .contact-form__actions {
      align-items: stretch;
      flex-direction: column;
    }

    .booking-card > .button {
      align-self: stretch;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-animate="contact"] [data-animate-item],
    [data-contact-step] > span,
    [data-contact-route]::after {
      opacity: 1;
      transform: none;
      animation: none;
      transition: none;
      will-change: auto;
    }

    .contact-card--form::after,
    .field-control::after {
      transform: none;
      transition: none;
    }

    .contact-form [data-form-submit][data-state="loading"]::after {
      opacity: 0;
      transform: none;
      animation: none;
    }

    .contact-form [data-form-submit][data-state="success"],
    .contact-form [data-form-submit][data-state="success"]::after {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
