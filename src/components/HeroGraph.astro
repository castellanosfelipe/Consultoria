<style>
  .hero-graph {
    width: 100%;
    margin: 0;
  }

  .hero-graph svg {
    width: 100%;
    height: auto;
  }

  .hero-graph__mobile {
    display: none;
  }

  .frame {
    fill: var(--paper-raised);
    stroke: var(--line);
    stroke-width: 2;
  }

  .meta,
  .node-label,
  .manual-chip text,
  .production-chip text,
  .mobile-status,
  .mobile-manual-status {
    font-family: var(--font-data);
  }

  .meta {
    fill: var(--graphite);
    font-size: var(--text-label);
    font-weight: 500;
    letter-spacing: 0.08em;
  }

  .meta--right,
  .node-label--right {
    text-anchor: end;
  }

  .node-label {
    fill: var(--ink);
    font-size: var(--text-label);
    font-weight: 500;
  }

  .edges path {
    fill: none;
    stroke: var(--graphite);
    stroke-width: 1.5;
  }

  .source-nodes circle {
    fill: var(--paper-raised);
    stroke: var(--ink);
    stroke-width: 2;
  }

  .broken-node circle {
    fill: var(--paper-raised);
    stroke: var(--manual);
    stroke-width: 2;
  }

  .broken-node path {
    stroke: var(--manual);
    stroke-linecap: round;
    stroke-width: 2.5;
  }

  .manual-chip rect {
    fill: var(--paper-raised);
    stroke: var(--manual);
  }

  .manual-chip circle {
    fill: var(--manual);
  }

  .manual-chip text {
    fill: var(--manual);
    font-size: var(--text-label);
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  .manual-network {
    transform-origin: center;
    animation: quiet-manual var(--graph-motion) both;
  }

  .pipeline {
    fill: none;
    stroke: var(--ink);
    stroke-dasharray: 446;
    stroke-dashoffset: 446;
    stroke-width: 3;
    animation: draw-line 800ms 760ms cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  .arrow {
    fill: var(--ink);
    opacity: 0;
    animation: appear 260ms 1.42s ease-out forwards;
  }

  .production-nodes circle {
    fill: var(--production);
    opacity: 0;
    transform-box: fill-box;
    transform-origin: center;
    animation: node-online 300ms calc(900ms + var(--delay)) cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  .production-chip {
    opacity: 0;
    transform: translateY(var(--space-2));
    animation: chip-online 360ms 1.32s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  .production-chip rect {
    fill: var(--production);
  }

  .production-chip circle {
    fill: var(--on-production);
  }

  .production-chip text {
    fill: var(--on-production);
    font-size: var(--text-label);
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  .mobile-transition {
    fill: none;
    stroke: var(--graphite);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.5;
  }

  @keyframes quiet-manual {
    0%, 42% { opacity: 1; transform: translateY(0); }
    76%, 100% { opacity: 0.32; transform: translateY(calc(-1 * var(--space-1))); }
  }

  @keyframes draw-line {
    to { stroke-dashoffset: 0; }
  }

  @keyframes appear {
    to { opacity: 1; }
  }

  @keyframes node-online {
    0% { opacity: 0; transform: scale(0.4); }
    100% { opacity: 1; transform: scale(1); }
  }

  @keyframes chip-online {
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 37.4375rem) {
    .hero-graph__desktop {
      display: none;
    }

    .hero-graph__mobile {
      display: block;
    }

    .pipeline--static {
      stroke-dasharray: none;
      stroke-dashoffset: 0;
      animation: none;
    }

    .arrow--static {
      opacity: 1;
      animation: none;
    }

    .production-nodes--static circle {
      opacity: 1;
      animation: none;
    }

    .mobile-status {
      fill: var(--production);
      font-size: var(--text-label);
      font-weight: 600;
      letter-spacing: 0.05em;
      text-anchor: middle;
    }

    .mobile-manual-status {
      fill: var(--manual);
      font-size: var(--text-tiny);
      font-weight: 600;
      letter-spacing: 0.05em;
      text-anchor: end;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .manual-network {
      opacity: 0.32;
      animation: none;
    }

    .pipeline {
      stroke-dashoffset: 0;
      animation: none;
    }

    .arrow,
    .production-nodes circle,
    .production-chip {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
