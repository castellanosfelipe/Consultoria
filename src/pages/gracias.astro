---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { withBasePath } from "../config";
---

<BaseLayout
  title="Siguiente paso | Felipe Peña"
  description="Continúa la conversación sobre software de operaciones con Felipe Peña."
  canonicalPath="/gracias/"
  noindex
>
  <SiteHeader />
  <main id="contenido" class="thanks-page">
    <div class="container">
      <div class="thanks-card" data-submission-confirmation>
        <span class="status-chip"><span class="status-dot"></span> <span data-confirmation-status>siguiente paso</span></span>
        <p class="eyebrow">Siguiente estado</p>
        <h1 data-confirmation-title>Sigamos la conversación.</h1>
        <p class="lead" data-confirmation-copy>Si todavía no compartiste tu contexto, vuelve al formulario: son solo tres campos.</p>
        <a class="button button--secondary" href={withBasePath("/")}>Volver al inicio <span class="icon-arrow" aria-hidden="true"></span></a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .thanks-page {
    min-height: calc(100vh - var(--header-height));
    display: grid;
    align-items: center;
    padding-block: var(--space-8);
  }

  .thanks-card {
    max-width: var(--reading);
    padding: clamp(var(--space-6), 6vw, var(--space-9));
    border: var(--border-strong) solid var(--ink);
    border-radius: var(--radius);
    background: var(--paper-raised);
    box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--line);
  }

  .thanks-card .eyebrow {
    margin-top: var(--space-7);
  }

  h1 {
    margin-top: var(--space-4);
  }

  .lead {
    margin-top: var(--space-5);
  }

  .button {
    margin-top: var(--space-6);
  }
</style>
