<div class="scroll-thread" data-scroll-thread aria-hidden="true" hidden>
  <svg
    class="scroll-thread__svg"
    viewBox="0 0 180 1000"
    preserveAspectRatio="none"
    focusable="false"
    role="presentation"
  >
    <defs>
      <clipPath id="scroll-thread-progress" clipPathUnits="userSpaceOnUse">
        <rect class="scroll-thread__clip" data-scroll-thread-clip x="0" y="-60" width="180" height="1120" />
      </clipPath>
    </defs>

    <path
      class="scroll-thread__track"
      data-scroll-thread-path
      pathLength="1"
      d="M142 -40 C28 70 168 154 82 250 C170 338 24 414 108 506 C176 610 32 704 122 792 C174 858 30 936 76 1040"
    />
    <g clip-path="url(#scroll-thread-progress)">
      <path
        class="scroll-thread__trail scroll-thread__trail--left"
        d="M142 -40 C28 70 168 154 82 250 C170 338 24 414 108 506 C176 610 32 704 122 792 C174 858 30 936 76 1040"
      />
      <path
        class="scroll-thread__trail"
        d="M142 -40 C28 70 168 154 82 250 C170 338 24 414 108 506 C176 610 32 704 122 792 C174 858 30 936 76 1040"
      />
      <path
        class="scroll-thread__trail scroll-thread__trail--right"
        d="M142 -40 C28 70 168 154 82 250 C170 338 24 414 108 506 C176 610 32 704 122 792 C174 858 30 936 76 1040"
      />
    </g>
  </svg>

  <span class="scroll-thread__packet" data-scroll-thread-packet>
    <i class="scroll-thread__packet-shadow"></i>
    <i class="scroll-thread__packet-core"></i>
    <i class="scroll-thread__packet-signal"></i>
  </span>
</div>

<style>
  .scroll-thread {
    position: fixed;
    z-index: 3;
    top: calc(var(--header-height) + var(--space-3));
    right: max(var(--space-2), calc((100vw - var(--container)) / 2 - 7rem));
    bottom: var(--space-3);
    width: clamp(5rem, 8vw, 8rem);
    overflow: visible;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--motion-slow) var(--motion-ease);
  }

  .scroll-thread.is-ready {
    opacity: 0.78;
  }

  .scroll-thread__svg {
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
  }

  .scroll-thread__track,
  .scroll-thread__trail {
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
  }

  .scroll-thread__track {
    stroke: color-mix(in srgb, var(--manual) 26%, var(--line));
    stroke-dasharray: 0.018 0.016;
    stroke-width: var(--border-strong);
  }

  .scroll-thread__trail {
    stroke: var(--production);
    stroke-width: var(--border-strong);
  }

  .scroll-thread__trail--left,
  .scroll-thread__trail--right {
    opacity: 0.3;
  }

  .scroll-thread__trail--left {
    transform: translateX(calc(-1 * var(--space-1)));
  }

  .scroll-thread__trail--right {
    transform: translateX(var(--space-1));
  }

  .scroll-thread__clip {
    transform: scaleY(0);
    transform-box: fill-box;
    transform-origin: top center;
  }

  .scroll-thread__packet {
    position: absolute;
    top: 0;
    left: 0;
    width: var(--space-7);
    height: var(--space-5);
    display: block;
    opacity: 0;
    transform: translate3d(-200%, -200%, 0);
    transform-origin: 50% 50%;
  }

  .scroll-thread.is-ready:not(.is-static) .scroll-thread__packet {
    opacity: 1;
  }

  .scroll-thread.is-moving .scroll-thread__packet {
    will-change: transform;
  }

  .scroll-thread__packet i {
    position: absolute;
    inset: 0;
    display: block;
    clip-path: polygon(0 12%, 100% 50%, 0 88%, 28% 50%);
  }

  .scroll-thread__packet-shadow {
    background: var(--ink);
    opacity: 0.24;
    transform: translateY(var(--space-1));
  }

  .scroll-thread__packet-core {
    background: var(--production);
    transform: scale(0.82);
  }

  .scroll-thread__packet-signal {
    background: var(--paper-raised);
    clip-path: polygon(5% 42%, 72% 50%, 5% 58%, 30% 50%);
  }

  .scroll-thread.is-static {
    opacity: 0.34;
  }

  .scroll-thread.is-static .scroll-thread__clip {
    transform: scaleY(1);
  }

  .scroll-thread.is-static .scroll-thread__packet {
    display: none;
  }

  @media (max-width: 56.25rem) {
    .scroll-thread {
      top: calc(var(--header-height) + var(--space-2));
      right: calc(-1 * var(--space-2));
      bottom: var(--space-2);
      width: var(--space-7);
    }

    .scroll-thread.is-ready {
      opacity: 0.38;
    }

    .scroll-thread__packet,
    .scroll-thread__trail--left,
    .scroll-thread__trail--right {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-thread {
      transition: none;
    }
  }
</style>
