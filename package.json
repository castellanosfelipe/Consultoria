{
  "name": "felipe-pena-landing",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.13.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/write-deploy-headers.mjs && node scripts/check-output.mjs && node scripts/check-budget.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "test": "npm run check && npm run build",
    "lighthouse": "lhci autorun",
    "audit:prod": "npm audit --omit=dev --audit-level=high"
  },
  "dependencies": {
    "astro": "7.0.9"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@lhci/cli": "0.15.1",
    "typescript": "6.0.3"
  },
  "overrides": {
    "@lhci/cli": {
      "inquirer": "8.2.7",
      "tmp": "0.2.7",
      "uuid": "11.1.1"
    }
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
